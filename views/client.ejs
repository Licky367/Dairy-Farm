<%- include("partials/layout", { title: "Electro Shop" }) %>

<style>
.hero{
padding:60px 40px;
text-align:center;
background:white;
}

.hero h1{
font-size:42px;
margin-bottom:15px;
color:#0b5d1e;
}

.hero p{
color:#666;
margin-bottom:25px;
}

.hero button{
background:#0b5d1e;
color:white;
border:none;
padding:14px 24px;
border-radius:10px;
cursor:pointer;
}

.products{
padding:40px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
}

.card{
background:white;
padding:18px;
border-radius:16px;
box-shadow:0 10px 20px rgba(0,0,0,.05);
}

.image{
height:170px;
background:#e8f5e9;
border-radius:12px;
margin-bottom:15px;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
}

.image img{
width:100%;
height:100%;
object-fit:cover;
}

.card h3{
margin-bottom:10px;
}

.card p{
font-size:14px;
color:#666;
margin-bottom:12px;
}

.price{
font-size:22px;
color:#0b5d1e;
font-weight:bold;
margin-bottom:10px;
}

.card button{
width:100%;
background:#0b5d1e;
color:white;
border:none;
padding:12px;
border-radius:10px;
cursor:pointer;
}
</style>

<section class="hero">
<h1>Medical Equipment Store</h1>
<p>Quality medical equipment with deposit payments and M-Pesa support.</p>
<button>Shop Now</button>
</section>

<section class="products">

<% if (products && products.length > 0) { %>

<% products.forEach(product => { %>
<div class="card">

<div class="image">
<% if (product.image) { %>
<img src="<%= product.image %>" alt="<%= product.name %>">
<% } %>
</div>

<h3><%= product.name %></h3>

<p><%= product.description %></p>

<div class="price">
KES <%= product.cost %>
</div>

<form action="/cart/add/<%= product.id %>" method="POST">
<button>Add to Cart</button>
</form>

</div>
<% }) %>

<% } else { %>

<p style="padding:20px;color:#777;">
No products available
</p>

<% } %>

</section>