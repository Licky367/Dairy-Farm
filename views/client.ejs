<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "Electro Shop" %></title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f8;
min-height:100vh;
}

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
}

/* TOP MENU */
.topmenu{
position:fixed;
top:70px;
left:0;
right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

.icon-group{
display:flex;
align-items:center;
gap:18px;
}

.icon-group a{
text-decoration:none;
font-size:22px;
color:#0b5d1e;
}

.profile-box{
position:relative;
}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.profile-box.active .dropdown{
display:block;
}

/* SIDEBAR */
.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{
left:0;
}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{
display:block;
}

/* MAIN */
.main{
padding:140px 25px 80px;
}

/* HERO */
.hero{
padding:60px 40px;
text-align:center;
background:#fff;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
margin-bottom:30px;
}

.hero h1{
font-size:42px;
margin-bottom:15px;
color:#0b5d1e;
}

.hero p{
color:#666;
margin-bottom:25px;
}

.hero button{
background:#0b5d1e;
color:#fff;
border:none;
padding:14px 24px;
border-radius:10px;
cursor:pointer;
}

/* PRODUCTS */
.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
}

.card{
background:#fff;
padding:18px;
border-radius:16px;
box-shadow:0 10px 20px rgba(0,0,0,.05);
}

.image{
height:170px;
background:#e8f5e9;
border-radius:12px;
margin-bottom:15px;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
}

.image img{
width:100%;
height:100%;
object-fit:cover;
}

.card h3{
margin-bottom:8px;
}

.card p{
font-size:14px;
color:#666;
margin-bottom:10px;
}

.price{
font-size:20px;
color:#0b5d1e;
font-weight:bold;
margin-bottom:10px;
}

.stock{
font-size:13px;
margin-bottom:10px;
font-weight:bold;
}

.instock{color:#0b5d1e;}
.lowstock{color:#b7791f;}
.outstock{color:#b42318;}

/* QTY */
.qty-box{
margin:10px 0;
}

.qty-controls{
display:flex;
align-items:center;
gap:8px;
}

.qty-controls button{
width:36px;
height:36px;
border:none;
border-radius:8px;
background:#0b5d1e;
color:#fff;
cursor:pointer;
font-size:18px;
}

.qty-controls input{
width:60px;
text-align:center;
padding:8px;
border:1px solid #ddd;
border-radius:8px;
}

/* BUTTON */
.card button{
width:100%;
background:#0b5d1e;
color:#fff;
border:none;
padding:12px;
border-radius:10px;
cursor:pointer;
margin-top:10px;
}

.card button:disabled{
background:#999;
cursor:not-allowed;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="topmenu">

<div style="display:flex;align-items:center;gap:15px;">
<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="icon-group">
<a href="/client">🏠</a>
<a href="/cart">🛒</a>
</div>
</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<% if(user){ %>
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/login">Login</a>
<a href="/signup">Sign Up</a>
<% } %>
</div>
</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/client">Home</a>
<a href="/cart">Cart</a>
<a href="/profile">Profile</a>
<% if(user){ %>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/login">Login</a>
<a href="/signup">Sign Up</a>
<% } %>
</div>

<div class="main">

<section class="hero">
<h1>Medical Equipment Store</h1>
<p>Quality medical equipment with deposit payments and M-Pesa support.</p>
<button onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">
Shop Now
</button>
</section>

<section class="products" id="products">

<% if(products && products.length > 0){ %>

<% products.forEach(product => { 
const stock = product.itemsAvailable || 0;
%>

<div class="card">

<div class="image">
<% if(product.image){ %>
<img src="<%= product.image %>" alt="<%= product.name %>">
<% } %>
</div>

<h3><%= product.name %></h3>

<p><%= product.description %></p>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<div class="stock 
<%= stock === 0 ? 'outstock' : stock <= 5 ? 'lowstock' : 'instock' %>">
Items Available: <%= stock %>
</div>

<form action="/cart/add/<%= product.id %>" method="POST">

<% if(stock > 0){ %>

<div class="qty-box">

<div class="qty-controls">
<button type="button" onclick="changeQty(this,-1,<%= stock %>)">−</button>

<input type="number"
name="quantity"
value="1"
min="1"
max="<%= stock %>"
readonly>

<button type="button" onclick="changeQty(this,1,<%= stock %>)">+</button>
</div>

</div>

<button type="submit">Add to Cart</button>

<% } else { %>

<button type="button" disabled>Out of Stock</button>

<% } %>

</form>

</div>

<% }) %>

<% } else { %>

<p style="color:#777;">No products available</p>

<% } %>

</section>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(e){
e.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click", function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});

/* QTY CONTROL */
function changeQty(btn, change, max){
const input = btn.parentElement.querySelector("input");
let value = parseInt(input.value);

value = value + change;

if(value < 1) value = 1;
if(value > max) value = max;

input.value = value;
}
</script>

</body>
</html>