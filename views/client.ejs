<style>

/* ================= HERO ================= */
.hero{
padding:50px 30px;
text-align:center;
background:#fff;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
margin-bottom:30px;
}

.hero h1{
font-size:34px;
margin-bottom:10px;
color:#0b5d1e;
}

.hero p{
color:#666;
margin-bottom:20px;
}

/* ================= CATEGORY ================= */
.category-section{
margin-bottom:40px;
}

.category-title{
font-size:20px;
margin:10px 0 15px;
color:#0b5d1e;
position:sticky;
top:0;
background:#f7f7f7;
padding:10px 0;
z-index:5;
}

/* ================= ROW ================= */
.products-row{
display:flex;
gap:14px;
overflow-x:auto;
padding:10px 5px 15px;
scroll-snap-type:x mandatory;
}

.products-row::-webkit-scrollbar{display:none;}
.products-row{scrollbar-width:none;}

/* ================= CARD (SMALLER) ================= */
.card{
background:#fff;
padding:12px;
border-radius:14px;
box-shadow:0 8px 18px rgba(0,0,0,.05);
min-width:180px;
flex:0 0 auto;
scroll-snap-align:start;
transition:.2s ease;
}

.card:hover{
transform:translateY(-4px);
}

/* IMAGE */
.image{
height:120px;
border-radius:10px;
overflow:hidden;
margin-bottom:10px;
background:#eee;
}

.image img{
width:100%;
height:100%;
object-fit:cover;
}

/* TEXT */
.card h3{
font-size:15px;
margin-bottom:6px;
white-space:nowrap;
overflow:hidden;
text-overflow:ellipsis;
}

.price{
font-size:16px;
font-weight:bold;
color:#0b5d1e;
margin-bottom:10px;
}

/* BUTTON */
.view-btn{
display:block;
text-align:center;
background:#0b5d1e;
color:#fff;
padding:10px;
border-radius:8px;
text-decoration:none;
font-size:13px;
}

.view-btn:hover{
opacity:.9;
}

/* ================= NAV ================= */
.slider-wrapper{position:relative;}

.nav-btn{
position:absolute;
top:40%;
transform:translateY(-50%);
background:rgba(0,0,0,.6);
color:#fff;
border:none;
width:36px;
height:36px;
border-radius:50%;
cursor:pointer;
z-index:10;
display:flex;
align-items:center;
justify-content:center;
}

.nav-left{left:-8px;}
.nav-right{right:-8px;}

</style>

<!-- ================= HERO ================= -->
<section class="hero">
<h1>Medical Equipment Store</h1>
<p>Quality medical equipment with flexible deposit payments.</p>

<button onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">
Shop Now
</button>
</section>

<!-- ================= PRODUCTS ================= -->
<section id="products">

<%
const groupedProducts = {};

products.forEach(p => {
    if(!groupedProducts[p.category]){
        groupedProducts[p.category] = [];
    }
    groupedProducts[p.category].push(p);
});
%>

<% if(products && products.length > 0){ %>

<% Object.keys(groupedProducts).forEach(category => { %>

<div class="category-section">

<h2 class="category-title"><%= category %></h2>

<div class="slider-wrapper">

<button class="nav-btn nav-left" onclick="scrollRow(this, -250)">‹</button>
<button class="nav-btn nav-right" onclick="scrollRow(this, 250)">›</button>

<div class="products-row">

<% groupedProducts[category].forEach(product => { %>

<div class="card">

<div class="image">
<% if(product.image){ %>
<img src="<%= product.image %>" alt="<%= product.name %>">
<% } %>
</div>

<h3><%= product.name %></h3>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<a href="/client/view/<%= product.id %>" class="view-btn">
View Product
</a>

</div>

<% }) %>

</div>
</div>
</div>

<% }) %>

<% } else { %>

<p style="color:#777;">No products available</p>

<% } %>

</section>

<!-- ================= SCRIPT ================= -->
<script>
function scrollRow(btn, distance){
const row = btn.parentElement.querySelector(".products-row");
row.scrollBy({ left: distance, behavior: "smooth" });
}
</script>