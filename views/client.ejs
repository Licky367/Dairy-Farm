<style>

/* ================= HERO ================= */
.hero{
padding:60px 40px;
text-align:center;
background:#fff;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
margin-bottom:30px;
}

.hero h1{
font-size:42px;
margin-bottom:15px;
color:#0b5d1e;
}

.hero p{
color:#666;
margin-bottom:25px;
}

.hero button{
background:#0b5d1e;
color:#fff;
border:none;
padding:14px 24px;
border-radius:10px;
cursor:pointer;
}

/* ================= CATEGORY SECTION ================= */
.category-section{
margin-bottom:45px;
}

/* sticky Netflix-style header */
.category-title{
font-size:22px;
margin:10px 0 15px;
color:#0b5d1e;
position:sticky;
top:0;
background:#f7f7f7;
padding:10px 0;
z-index:5;
}

/* ================= SLIDER ROW ================= */
.slider-wrapper{
position:relative;
}

.products-row{
display:flex;
gap:18px;
overflow-x:auto;
scroll-behavior:smooth;
padding:10px 5px 20px;
scroll-snap-type:x mandatory;
}

/* hide scrollbar */
.products-row::-webkit-scrollbar{
display:none;
}

.products-row{
-ms-overflow-style:none;
scrollbar-width:none;
}

/* CARD */
.card{
background:#fff;
padding:18px;
border-radius:16px;
box-shadow:0 10px 20px rgba(0,0,0,.05);
min-width:240px;
flex:0 0 auto;
scroll-snap-align:start;
transition:transform .2s ease;
}

.card:hover{
transform:scale(1.03);
}

/* IMAGE */
.image{
height:170px;
background:#e8f5e9;
border-radius:12px;
margin-bottom:15px;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
}

.image img{
width:100%;
height:100%;
object-fit:cover;
}

/* TEXT */
.card h3{margin-bottom:8px;}

.card p{
font-size:14px;
color:#666;
margin-bottom:10px;
}

/* PRICE */
.price{
font-size:20px;
color:#0b5d1e;
font-weight:bold;
margin-bottom:10px;
}

/* STOCK */
.stock{
font-size:13px;
margin-bottom:10px;
font-weight:bold;
}

.instock{color:#0b5d1e;}
.lowstock{color:#b7791f;}
.outstock{color:#b42318;}

/* QTY */
.qty-box{margin:10px 0;}

.qty-controls{
display:flex;
align-items:center;
gap:8px;
}

.qty-controls button{
width:36px;height:36px;
border:none;border-radius:8px;
background:#0b5d1e;
color:#fff;
cursor:pointer;
font-size:18px;
}

.qty-controls input{
width:60px;
text-align:center;
padding:8px;
border:1px solid #ddd;
border-radius:8px;
}

/* BUTTON */
.card button{
width:100%;
background:#0b5d1e;
color:#fff;
border:none;
padding:12px;
border-radius:10px;
cursor:pointer;
margin-top:10px;
}

.card button:disabled{
background:#999;
cursor:not-allowed;
}

/* ================= NAV ARROWS ================= */
.nav-btn{
position:absolute;
top:40%;
transform:translateY(-50%);
background:rgba(0,0,0,.6);
color:#fff;
border:none;
width:40px;
height:40px;
border-radius:50%;
cursor:pointer;
z-index:10;
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
}

.nav-left{left:-10px;}
.nav-right{right:-10px;}

.nav-btn:hover{
background:rgba(0,0,0,.8);
}

</style>

<!-- ================= HERO ================= -->
<section class="hero">
<h1>Medical Equipment Store</h1>
<p>Quality medical equipment with deposit payments and M-Pesa support.</p>

<button onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">
Shop Now
</button>
</section>

<!-- ================= PRODUCTS ================= -->
<section id="products">

<%
const groupedProducts = {};

products.forEach(p => {
    if(!groupedProducts[p.category]){
        groupedProducts[p.category] = [];
    }
    groupedProducts[p.category].push(p);
});
%>

<% if(products && products.length > 0){ %>

<% Object.keys(groupedProducts).forEach(category => { %>

<div class="category-section">

<h2 class="category-title"><%= category %></h2>

<div class="slider-wrapper">

<button class="nav-btn nav-left" onclick="scrollRow(this, -300)">‹</button>
<button class="nav-btn nav-right" onclick="scrollRow(this, 300)">›</button>

<div class="products-row">

<% groupedProducts[category].forEach(product => { 
const stock = product.itemsAvailable || 0;
%>

<div class="card">

<div class="image">
<% if(product.image){ %>
<img src="<%= product.image %>" alt="<%= product.name %>">
<% } %>
</div>

<h3><%= product.name %></h3>

<p><%= product.description %></p>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<div class="stock 
<%= stock === 0 ? 'outstock' : stock <= 5 ? 'lowstock' : 'instock' %>">
Items Available: <%= stock %>
</div>

<form action="/cart/add/<%= product.id %>" method="POST">

<% if(stock > 0){ %>

<div class="qty-box">
<div class="qty-controls">
<button type="button" onclick="changeQty(this,-1,<%= stock %>)">−</button>

<input type="number"
name="quantity"
value="1"
min="1"
max="<%= stock %>"
readonly>

<button type="button" onclick="changeQty(this,1,<%= stock %>)">+</button>
</div>
</div>

<button type="submit">Add to Cart</button>

<% } else { %>

<button type="button" disabled>Out of Stock</button>

<% } %>

</form>

</div>

<% }) %>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<p style="color:#777;">No products available</p>

<% } %>

</section>

<!-- ================= SCRIPT ================= -->
<script>

/* QTY CONTROL */
function changeQty(btn, change, max){
const input = btn.parentElement.querySelector("input");

let value = parseInt(input.value);
value = value + change;

if(value < 1) value = 1;
if(value > max) value = max;

input.value = value;
}

/* SLIDER CONTROL */
function scrollRow(btn, distance){
const row = btn.parentElement.querySelector(".products-row");
row.scrollBy({ left: distance, behavior: "smooth" });
}

</script>