<style>
.hero{
padding:60px 40px;
text-align:center;
background:#fff;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
margin-bottom:30px;
}

.hero h1{
font-size:42px;
margin-bottom:15px;
color:#0b5d1e;
}

.hero p{
color:#666;
margin-bottom:25px;
}

.hero button{
background:#0b5d1e;
color:#fff;
border:none;
padding:14px 24px;
border-radius:10px;
cursor:pointer;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
gap:25px;
}

.card{
background:#fff;
padding:18px;
border-radius:16px;
box-shadow:0 10px 20px rgba(0,0,0,.05);
}

.image{
height:170px;
background:#e8f5e9;
border-radius:12px;
margin-bottom:15px;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
}

.image img{
width:100%;
height:100%;
object-fit:cover;
}

.card h3{margin-bottom:8px;}

.card p{
font-size:14px;
color:#666;
margin-bottom:10px;
}

.price{
font-size:20px;
color:#0b5d1e;
font-weight:bold;
margin-bottom:10px;
}

.stock{
font-size:13px;
margin-bottom:10px;
font-weight:bold;
}

.instock{color:#0b5d1e;}
.lowstock{color:#b7791f;}
.outstock{color:#b42318;}

.qty-box{margin:10px 0;}

.qty-controls{
display:flex;
align-items:center;
gap:8px;
}

.qty-controls button{
width:36px;height:36px;
border:none;border-radius:8px;
background:#0b5d1e;
color:#fff;
cursor:pointer;
font-size:18px;
}

.qty-controls input{
width:60px;
text-align:center;
padding:8px;
border:1px solid #ddd;
border-radius:8px;
}

.card button{
width:100%;
background:#0b5d1e;
color:#fff;
border:none;
padding:12px;
border-radius:10px;
cursor:pointer;
margin-top:10px;
}

.card button:disabled{
background:#999;
cursor:not-allowed;
}
</style>


<section class="hero">
<h1>Medical Equipment Store</h1>
<p>Quality medical equipment with deposit payments and M-Pesa support.</p>

<button onclick="document.getElementById('products').scrollIntoView({behavior:'smooth'})">
Shop Now
</button>
</section>


<section class="products" id="products">

<% if(products && products.length > 0){ %>

<% products.forEach(product => { 
const stock = product.itemsAvailable || 0;
%>

<div class="card">

<div class="image">
<% if(product.image){ %>
<img src="<%= product.image %>" alt="<%= product.name %>">
<% } %>
</div>

<h3><%= product.name %></h3>

<p><%= product.description %></p>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<div class="stock 
<%= stock === 0 ? 'outstock' : stock <= 5 ? 'lowstock' : 'instock' %>">
Items Available: <%= stock %>
</div>

<form action="/cart/add/<%= product.id %>" method="POST">

<% if(stock > 0){ %>

<div class="qty-box">

<div class="qty-controls">
<button type="button" onclick="changeQty(this,-1,<%= stock %>)">−</button>

<input type="number"
name="quantity"
value="1"
min="1"
max="<%= stock %>"
readonly>

<button type="button" onclick="changeQty(this,1,<%= stock %>)">+</button>
</div>

</div>

<button type="submit">Add to Cart</button>

<% } else { %>

<button type="button" disabled>Out of Stock</button>

<% } %>

</form>

</div>

<% }) %>

<% } else { %>

<p style="color:#777;">No products available</p>

<% } %>

</section>


<% script = `
<script>

/* QTY CONTROL */
function changeQty(btn, change, max){
const input = btn.parentElement.querySelector("input");

let value = parseInt(input.value);
value = value + change;

if(value < 1) value = 1;
if(value > max) value = max;

input.value = value;
}

</script>
` %>