<%- include("../partials/layout", { title: "Financial Analytics" }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/chart.js">

<style>
.container {
    padding: 20px;
}

/* ================= CARDS ================= */
.cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 25px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.card h3 {
    margin: 0;
    font-size: 14px;
    color: #666;
}

.card h2 {
    margin-top: 8px;
}

/* ================= CHARTS ================= */
.grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
}

.box {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

/* chart header row */
.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.back-btn {
    display: none;
    padding: 6px 12px;
    border: none;
    background: #0b5d1e;
    color: #fff;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
}

.back-btn.active {
    display: inline-block;
}

/* ================= TABLE ================= */
table {
    width: 100%;
    border-collapse: collapse;
}

th, td {
    padding: 10px;
    border-bottom: 1px solid #eee;
    text-align: left;
}

/* ================= MOBILE ================= */
@media (max-width: 768px) {
    .cards {
        grid-template-columns: 1fr;
    }
}
</style>

<div class="container">

<!-- FILTER -->
<form method="GET" action="/admin/stats">
    <input type="number" name="month" placeholder="Month" />
    <input type="number" name="year" placeholder="Year" />
    <button type="submit">Filter</button>
</form>

<!-- CARDS -->
<div class="cards">
    <div class="card">
        <h3>Revenue</h3>
        <h2>KES <%= financial.revenue %></h2>
    </div>

    <div class="card">
        <h3>Profit</h3>
        <h2>KES <%= financial.profit %></h2>
    </div>

    <div class="card">
        <h3>Net Profit</h3>
        <h2>KES <%= financial.netProfit %></h2>
    </div>

    <div class="card">
        <h3>Orders</h3>
        <h2><%= financial.orders %></h2>
    </div>
</div>

<!-- CHARTS -->
<div class="grid">

    <!-- MAJOR CATEGORY -->
    <div class="box">
        <div class="chart-header">
            <h3>Major Category Performance</h3>
            <button id="backBtn" class="back-btn" onclick="resetCategories()">Back</button>
        </div>
        <canvas id="majorChart"></canvas>
    </div>

    <!-- CATEGORY -->
    <div class="box">
        <h3 id="categoryTitle">Category Performance</h3>
        <canvas id="categoryChart"></canvas>
    </div>

</div>

<!-- PRODUCT TABLE -->
<div class="box" style="margin-top:20px;">
    <h3>Top Products</h3>

    <table>
        <thead>
        <tr>
            <th>Product</th>
            <th>Revenue</th>
            <th>Profit</th>
            <th>Units</th>
        </tr>
        </thead>

        <tbody>
        <% productStats.slice(0, 10).forEach(p => { %>
            <tr>
                <td><%= p.name %></td>
                <td><%= p.revenue %></td>
                <td><%= p.profit %></td>
                <td><%= p.unitsSold %></td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</div>

</div>

<script>
let majorData = <%- JSON.stringify(majorCategoryStats) %>;
let categoryData = <%- JSON.stringify(categoryStats) %>;

let categoryChart;
let majorChart;

// =========================
// CATEGORY RENDER
// =========================
function renderCategoryChart(data, label = "Category Performance") {

    document.getElementById("categoryTitle").innerText = label;

    if (categoryChart) categoryChart.destroy();

    categoryChart = new Chart(document.getElementById("categoryChart"), {
        type: "bar",
        data: {
            labels: data.map(c => c.category),
            datasets: [{
                label: "Revenue",
                data: data.map(c => c.revenue)
            }]
        }
    });
}

// =========================
// MAJOR CHART
// =========================
majorChart = new Chart(document.getElementById("majorChart"), {
    type: "pie",
    data: {
        labels: majorData.map(m => m.majorCategory),
        datasets: [{
            data: majorData.map(m => m.revenue)
        }]
    }
});

// CLICK → DRILL DOWN
document.getElementById("majorChart").onclick = async function(evt) {

    const points = majorChart.getElementsAtEventForMode(
        evt,
        'nearest',
        { intersect: true },
        true
    );

    if (!points.length) return;

    const index = points[0].index;
    const selectedMajor = majorData[index].majorCategory;

    const res = await fetch(
        `/admin/category-stats?month=${<%= financial.month || '' %>}&year=${<%= financial.year || '' %>}&majorCategory=${selectedMajor}`
    );

    const filtered = await res.json();

    renderCategoryChart(filtered, selectedMajor + " Categories");

    document.getElementById("backBtn").classList.add("active");
};

// RESET → ALL CATEGORIES
function resetCategories() {
    renderCategoryChart(categoryData, "Category Performance");
    document.getElementById("backBtn").classList.remove("active");
}

// INIT
renderCategoryChart(categoryData);
</script>