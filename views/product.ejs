<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= product.name %></title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f8;
min-height:100vh;
color:#222;
}

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
text-align:center;
padding:0 15px;
}

/* TOP MENU */
.topmenu{
position:fixed;
top:70px;
left:0;
right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

.icon-group{
display:flex;
align-items:center;
gap:18px;
}

.icon-group a{
text-decoration:none;
font-size:20px;
color:#0b5d1e;
}

/* PROFILE */
.profile-box{
position:relative;
}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.dropdown a:hover{
background:#f7f7f7;
}

.profile-box.active .dropdown{
display:block;
}

/* SIDEBAR */
.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{
left:0;
}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
transition:.3s;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{
display:block;
}

/* MAIN */
.main{
padding:140px 25px 80px;
}

/* CARD */
.card{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
max-width:1000px;
margin:auto;
}

.product-wrapper{
display:flex;
gap:30px;
flex-wrap:wrap;
align-items:flex-start;
}

.product-image{
width:320px;
max-width:100%;
border-radius:12px;
object-fit:cover;
background:#eee;
}

.product-info{
flex:1;
min-width:280px;
}

.product-info h2{
font-size:30px;
margin-bottom:10px;
}

.description{
color:#666;
line-height:1.7;
margin-bottom:15px;
}

.price{
font-size:28px;
font-weight:bold;
color:#0b5d1e;
margin-bottom:10px;
}

.meta{
font-size:15px;
margin-bottom:10px;
line-height:1.6;
}

/* STOCK BADGES */
.stock{
display:inline-block;
padding:8px 14px;
border-radius:30px;
font-size:13px;
font-weight:bold;
margin:10px 0;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

/* QUANTITY SELECTOR */
.qty-box{
margin-top:15px;
margin-bottom:10px;
}

.qty-box label{
display:block;
margin-bottom:8px;
font-weight:bold;
font-size:14px;
}

.qty-controls{
display:flex;
align-items:center;
gap:10px;
}

.qty-controls button{
width:40px;
height:40px;
border:none;
border-radius:8px;
background:#0b5d1e;
color:#fff;
font-size:20px;
cursor:pointer;
display:flex;
align-items:center;
justify-content:center;
}

.qty-controls input{
width:70px;
text-align:center;
padding:10px;
border:1px solid #ddd;
border-radius:8px;
font-size:16px;
}

small{
color:gray;
}

/* BUTTON */
button.add-btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:8px;
cursor:pointer;
margin-top:15px;
font-size:15px;
min-width:220px;
}

button:disabled{
background:#999;
cursor:not-allowed;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
padding:0 10px;
text-align:center;
}

/* RESPONSIVE */
@media(max-width:768px){
.main{padding:140px 15px 80px;}
.product-info h2{font-size:24px;}
.price{font-size:24px;}
button.add-btn{width:100%;min-width:auto;}
}
</style>
</head>

<body>

<div class="header">
Corevester Investments Limited
</div>

<div class="topmenu">

<div style="display:flex;align-items:center;gap:15px;">
<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="icon-group">
<a href="/client">🏠</a>
<a href="/client/cart">🛒</a>
</div>
</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<% if(user){ %>
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/login">Login</a>
<a href="/signup">Sign Up</a>
<% } %>
</div>
</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/client">Home</a>
<a href="/client/cart">Cart</a>
<a href="/profile">Profile</a>
<% if(user){ %>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/login">Login</a>
<a href="/signup">Sign Up</a>
<% } %>
</div>

<div class="main">

<div class="card">

<div class="product-wrapper">

<img src="<%= product.image || 'https://via.placeholder.com/300' %>"
class="product-image"
alt="<%= product.name %>">

<div class="product-info">

<h2><%= product.name %></h2>

<p class="description"><%= product.description %></p>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<div class="meta">
Deposit: <b><%= product.depositPercentage %>%</b>
(KES <%= Number(product.depositAmount).toLocaleString() %>)
</div>

<div class="meta">
<b>Category:</b> <%= product.category %>
</div>

<div class="meta">
<b>Items Available:</b> <%= product.itemsAvailable || 0 %>
</div>

<% if((product.itemsAvailable || 0) === 0){ %>
<div class="stock outstock">Out of Stock</div>
<% } else if((product.itemsAvailable || 0) <= 5){ %>
<div class="stock lowstock">Low Stock</div>
<% } else { %>
<div class="stock instock">In Stock</div>
<% } %>

<form action="/cart/add/<%= product.id %>" method="POST">

<% if((product.itemsAvailable || 0) > 0){ %>

<div class="qty-box">

<label>Quantity</label>

<div class="qty-controls">

<button type="button" onclick="decreaseQty()">−</button>

<input
type="number"
name="quantity"
id="quantity"
value="1"
min="1"
max="<%= product.itemsAvailable || 0 %>"
readonly
>

<button type="button" onclick="increaseQty()">+</button>

</div>

<small>Max available: <%= product.itemsAvailable || 0 %></small>

</div>

<button type="submit" class="add-btn">
Add to Cart
</button>

<% } else { %>

<button type="button" class="add-btn" disabled>
Unavailable
</button>

<% } %>

</form>

</div>

</div>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(event){
event.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click", function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});

/* QUANTITY LOGIC */
const maxQty = <%= product.itemsAvailable || 0 %>;

function increaseQty(){
let qty = document.getElementById("quantity");
let val = parseInt(qty.value);

if(val < maxQty){
qty.value = val + 1;
}
}

function decreaseQty(){
let qty = document.getElementById("quantity");
let val = parseInt(qty.value);

if(val > 1){
qty.value = val - 1;
}
}
</script>

</body>
</html>