<% layout('layout', { title: product.name }) %>

<style>
/* CARD */
.card{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
max-width:1000px;
margin:auto;
}

.product-wrapper{
display:flex;
gap:30px;
flex-wrap:wrap;
align-items:flex-start;
}

.product-image{
width:320px;
max-width:100%;
border-radius:12px;
object-fit:cover;
background:#eee;
}

.product-info{
flex:1;
min-width:280px;
}

.product-info h2{
font-size:30px;
margin-bottom:10px;
}

.description{
color:#666;
line-height:1.7;
margin-bottom:15px;
}

.price{
font-size:28px;
font-weight:bold;
color:#0b5d1e;
margin-bottom:10px;
}

.meta{
font-size:15px;
margin-bottom:10px;
line-height:1.6;
}

/* STOCK BADGES */
.stock{
display:inline-block;
padding:8px 14px;
border-radius:30px;
font-size:13px;
font-weight:bold;
margin:10px 0;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

/* QUANTITY */
.qty-box{
margin-top:15px;
margin-bottom:10px;
}

.qty-box label{
display:block;
margin-bottom:8px;
font-weight:bold;
font-size:14px;
}

.qty-controls{
display:flex;
align-items:center;
gap:10px;
}

.qty-controls button{
width:40px;
height:40px;
border:none;
border-radius:8px;
background:#0b5d1e;
color:#fff;
font-size:20px;
cursor:pointer;
display:flex;
align-items:center;
justify-content:center;
}

.qty-controls input{
width:70px;
text-align:center;
padding:10px;
border:1px solid #ddd;
border-radius:8px;
font-size:16px;
}

small{
color:gray;
}

/* BUTTON */
button.add-btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:8px;
cursor:pointer;
margin-top:15px;
font-size:15px;
min-width:220px;
}

button:disabled{
background:#999;
cursor:not-allowed;
}

/* RESPONSIVE */
@media(max-width:768px){
.product-info h2{font-size:24px;}
.price{font-size:24px;}
button.add-btn{width:100%;min-width:auto;}
}
</style>

<div class="card">

<div class="product-wrapper">

<img src="<%= product.image || 'https://via.placeholder.com/300' %>"
class="product-image"
alt="<%= product.name %>">

<div class="product-info">

<h2><%= product.name %></h2>

<p class="description"><%= product.description %></p>

<div class="price">
KES <%= Number(product.cost).toLocaleString() %>
</div>

<div class="meta">
Deposit: <b><%= product.depositPercentage %>%</b>
(KES <%= Number(product.depositAmount).toLocaleString() %>)
</div>

<div class="meta">
<b>Category:</b> <%= product.category %>
</div>

<div class="meta">
<b>Items Available:</b> <%= product.itemsAvailable || 0 %>
</div>

<% if((product.itemsAvailable || 0) === 0){ %>
<div class="stock outstock">Out of Stock</div>
<% } else if((product.itemsAvailable || 0) <= 5){ %>
<div class="stock lowstock">Low Stock</div>
<% } else { %>
<div class="stock instock">In Stock</div>
<% } %>

<form action="/cart/add/<%= product.id %>" method="POST">

<% if((product.itemsAvailable || 0) > 0){ %>

<div class="qty-box">

<label>Quantity</label>

<div class="qty-controls">

<button type="button" onclick="decreaseQty()">−</button>

<input
type="number"
name="quantity"
id="quantity"
value="1"
min="1"
max="<%= product.itemsAvailable || 0 %>"
readonly
>

<button type="button" onclick="increaseQty()">+</button>

</div>

<small>Max available: <%= product.itemsAvailable || 0 %></small>

</div>

<button type="submit" class="add-btn">
Add to Cart
</button>

<% } else { %>

<button type="button" class="add-btn" disabled>
Unavailable
</button>

<% } %>

</form>

</div>

</div>

</div>

<script>
const maxQty = <%= product.itemsAvailable || 0 %>;

function increaseQty(){
let qty = document.getElementById("quantity");
let val = parseInt(qty.value);
if(val < maxQty){
qty.value = val + 1;
}
}

function decreaseQty(){
let qty = document.getElementById("quantity");
let val = parseInt(qty.value);
if(val > 1){
qty.value = val - 1;
}
}
</script>