<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Checkout</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}

body{background:#f4f6f8;min-height:100vh;}

.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;
z-index:1000;
}

.main{padding:150px 25px 90px;}

.checkout-box{
max-width:900px;
margin:auto;
background:#fff;
padding:30px;
border-radius:16px;
box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.item{
display:flex;
justify-content:space-between;
padding:14px 0;
border-bottom:1px solid #eee;
}

.summary{margin-top:20px;line-height:2;}

input, textarea{
width:100%;
padding:10px;
margin-top:6px;
margin-bottom:12px;
border-radius:8px;
border:1px solid #ccc;
}

label{font-size:14px;color:#333;}

button{
background:#0b5d1e;
color:#fff;
border:none;
padding:15px;
border-radius:10px;
width:100%;
cursor:pointer;
font-size:16px;
}

button:disabled{background:#999;cursor:not-allowed;}

.warning{
color:#b42318;
margin-top:12px;
display:none;
}

.note{
font-size:13px;
color:#666;
margin-bottom:10px;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="main">

<div class="checkout-box">

<h1>Checkout</h1>

<hr style="margin:15px 0;">

<h3>Items</h3>

<% let hasStockIssue = false; %>

<% cart.forEach(item => { %>

<% if(item.quantity > (item.itemsAvailable || 0)) hasStockIssue = true; %>

<div class="item">
<div>
<b><%= item.name %></b><br>
Qty: <%= item.quantity %> | Stock: <%= item.itemsAvailable || 0 %>
</div>

<div>
KES <%= (item.cost * item.quantity).toLocaleString() %>
</div>
</div>

<% }) %>

<div class="summary">

<h3>Total: KES <%= totals.total.toLocaleString() %></h3>
<p>Deposit: KES <%= totals.deposit.toLocaleString() %></p>
<p>Arrear: KES <%= totals.arrear.toLocaleString() %></p>

</div>

<p class="warning" id="warning">
⚠ Some items exceed available stock. Please adjust your cart.
</p>

<!-- ================= DELIVERY INFO ================= -->

<h3 style="margin-top:25px;">Delivery Information</h3>

<p class="note">
Enter details or allow GPS detection for accurate delivery
</p>

<label>Delivery Address</label>
<textarea id="address" placeholder="e.g. Kilimani, Nairobi, House No..." required></textarea>

<label>Google Maps Location URL (optional)</label>
<input type="text" id="locationUrl" placeholder="Paste pinned Google Maps link">

<label>Location Notes</label>
<textarea id="locationText" placeholder="Landmarks, gate color, directions..."></textarea>

<!-- ================= NEW: DELIVERY DATE ================= -->

<label>Expected Delivery Date</label>
<input type="date" id="expectedDeliveryDate">

<!-- ================= GPS BUTTON ================= -->

<button type="button" onclick="getLocation()" style="margin-bottom:10px;">
Use My Current Location
</button>

<input type="hidden" id="lat">
<input type="hidden" id="lng">

<form method="POST" action="/checkout" id="checkoutForm">

<input type="hidden" name="cartData" value='<%= JSON.stringify(cart) %>'>

<input type="hidden" name="deliveryData" id="deliveryData">

<h3 style="margin:15px 0;">Payment Method</h3>

<label><input type="radio" name="paymentType" value="paid" required> Pay Full</label><br>
<label><input type="radio" name="paymentType" value="depositPaid"> Pay Deposit</label><br>
<label><input type="radio" name="paymentType" value="payAfter"> Pay Upon Delivery</label><br>

<br>

<button type="submit" id="checkoutBtn">
Order Now
</button>

</form>

</div>

</div>

<script>
const hasIssue = <%= hasStockIssue ? "true" : "false" %>;

const btn = document.getElementById("checkoutBtn");
const warning = document.getElementById("warning");

if(hasIssue){
btn.disabled = true;
warning.style.display = "block";
}

/* ================= GPS LOCATION (WHATSAPP STYLE) ================= */

function getLocation() {

    if (!navigator.geolocation) {
        alert("Geolocation not supported");
        return;
    }

    navigator.geolocation.getCurrentPosition((position) => {

        document.getElementById("lat").value = position.coords.latitude;
        document.getElementById("lng").value = position.coords.longitude;

        alert("Location captured successfully");

    }, () => {
        alert("Permission denied or unavailable");
    });
}

/* ================= FORM SUBMIT ================= */

document.getElementById("checkoutForm").addEventListener("submit", function () {

    const deliveryData = {
        address: document.getElementById("address").value,
        locationUrl: document.getElementById("locationUrl").value,
        locationText: document.getElementById("locationText").value,

        // GPS (new)
        locationLat: document.getElementById("lat").value || null,
        locationLng: document.getElementById("lng").value || null,

        // new feature
        expectedDeliveryDate: document.getElementById("expectedDeliveryDate").value || null
    };

    document.getElementById("deliveryData").value =
        JSON.stringify(deliveryData);
});
</script>

</body>
</html>