<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "Admin Panel" %></title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#f4f6f8;
min-height:100vh;
}

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
box-shadow:0 4px 10px rgba(0,0,0,.1);
}

/* TOP MENU */
.topmenu{
position:fixed;
top:70px;
left:0;
right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

/* MENU ICON */
.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

/* PROFILE */
.profile-box{
position:relative;
}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.dropdown a:hover{
background:#f4f6f8;
}

.profile-box.active .dropdown{
display:block;
}

/* SIDEBAR */
.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{
left:0;
}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
transition:.3s;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{
display:block;
}

/* MAIN CONTENT */
.main{
padding:140px 25px 80px;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
}

/* RESPONSIVE */
@media(max-width:768px){

.header{
font-size:18px;
}

.main{
padding:140px 15px 80px;
}

.profile-btn{
font-size:13px;
padding:8px 12px;
}

}
</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
Corevester Investments Limited
</div>

<!-- TOP MENU -->
<div class="topmenu">

<div class="menu-btn" onclick="openSidebar()">
☰
</div>

<div class="profile-box" id="profileBox">

<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<a href="/profile">Profile</a>
<a href="/logout">Logout</a>
</div>

</div>

</div>

<!-- OVERLAY -->
<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<a href="/profile">Profile</a>
<a href="/logout">Logout</a>

</div>

<!-- MAIN CONTENT START -->
<div class="main">