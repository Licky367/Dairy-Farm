<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Chessy Dairies</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, Helvetica, sans-serif;
}

body{
background:#f5f5f5;
}

header{
background:#0b5d1e;
padding:15px 40px;
color:white;
display:flex;
justify-content:space-between;
align-items:center;
}

header h2{
font-size:24px;
}

nav a{
color:white;
text-decoration:none;
margin-left:20px;
font-weight:bold;
}

.container{
max-width:1100px;
margin:auto;
padding:30px;
}

.card{
background:white;
padding:30px;
border-radius:15px;
box-shadow:0 4px 20px rgba(0,0,0,0.08);
}

input{
width:100%;
padding:14px;
margin-top:8px;
margin-bottom:18px;
border:1px solid #ddd;
border-radius:10px;
font-size:16px;
}

button{
background:#0b5d1e;
color:white;
border:none;
padding:14px 20px;
border-radius:10px;
cursor:pointer;
font-size:16px;
width:100%;
}

button:hover{
background:#084516;
}

.profile-top{
display:flex;
align-items:center;
gap:25px;
margin-bottom:30px;
}

.avatar{
width:120px;
height:120px;
border-radius:50%;
background:#0b5d1e;
color:white;
font-size:45px;
display:flex;
align-items:center;
justify-content:center;
font-weight:bold;
}

.info h2{
font-size:28px;
color:#111;
}

.info p{
color:gray;
margin-top:5px;
}

@media(max-width:768px){

.profile-top{
flex-direction:column;
text-align:center;
}

header{
flex-direction:column;
gap:10px;
}

nav a{
margin:0 10px;
}

}

</style>
</head>

<body>

<header>
<h2>Chessy Dairies</h2>

<nav>
<a href="/">Home</a>
<a href="/profile">Profile</a>
<a href="/logout">Logout</a>
</nav>
</header>

<div class="container">