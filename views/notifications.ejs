<div class="container-fluid py-4">

  <div class="card shadow-sm">
    <div class="card-body">

      <h4 class="mb-4">Send Notification</h4>

      <!-- ALERTS -->
      <% if (query && query.success) { %>
        <div class="alert alert-success">Notification sent successfully</div>
      <% } %>

      <% if (query && query.error) { %>
        <div class="alert alert-danger">Failed to send notification</div>
      <% } %>

      <form action="/notifications/send" method="POST" id="notificationForm">

        <!-- CHANNEL -->
        <div class="mb-3">
          <label class="form-label">Channel</label>
          <select name="channel" id="channel" class="form-select" required>
            <option value="">-- Select Channel --</option>
            <option value="email">Email</option>
            <option value="sms">SMS</option>
            <option value="whatsapp">WhatsApp</option>
          </select>
        </div>

        <!-- SEND TO ALL -->
        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" id="sendToAll" name="sendToAll">
          <label class="form-check-label">Send to all users</label>
        </div>

        <!-- USER SELECT -->
        <div class="mb-3" id="userSelectWrapper">
          <label class="form-label">Select Users</label>
          <select id="userSelect" name="userIds" multiple>
            <% users.forEach(user => { %>
              <option 
                value="<%= user._id %>" 
                data-email="<%= user.email %>" 
                data-phone="<%= user.phone %>">
                <%= user.name %> | <%= user.email %> | <%= user.phone %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- MANUAL INPUTS -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Manual Emails</label>
            <input type="text" name="manualEmails" class="form-control" placeholder="a@gmail.com, b@mail.com">
          </div>

          <div class="col-md-6 mb-3">
            <label class="form-label">Manual Phones</label>
            <input type="text" name="manualPhones" class="form-control" placeholder="+2547XXXXXXXX">
          </div>
        </div>

        <!-- MESSAGE -->
        <div class="mb-3">
          <label class="form-label d-flex justify-content-between">
            Message
            <span id="charCount" class="text-muted small">0 chars</span>
          </label>

          <textarea id="message" name="message" rows="5" class="form-control" required></textarea>

          <small id="smsInfo" class="text-muted d-none">
            SMS segments: <span id="smsSegments">1</span>
          </small>
        </div>

        <!-- PREVIEW -->
        <div class="mb-4">
          <label class="form-label">Preview</label>

          <div class="border rounded p-3 bg-light" id="previewBox">
            <em class="text-muted">Message preview will appear here...</em>
          </div>
        </div>

        <!-- SUBMIT -->
        <div class="d-flex justify-content-end">
          <button class="btn btn-primary">
            Send Notification
          </button>
        </div>

      </form>

    </div>
  </div>

</div>

<!-- TomSelect CDN -->
<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

<script>
  const channel = document.getElementById("channel");
  const message = document.getElementById("message");
  const previewBox = document.getElementById("previewBox");
  const charCount = document.getElementById("charCount");
  const smsInfo = document.getElementById("smsInfo");
  const smsSegments = document.getElementById("smsSegments");
  const sendToAll = document.getElementById("sendToAll");
  const userWrapper = document.getElementById("userSelectWrapper");

  // TomSelect init
  const userSelect = new TomSelect("#userSelect", {
    plugins: ['remove_button'],
    persist: false,
    create: false
  });

  // Toggle user select
  sendToAll.addEventListener("change", () => {
    userWrapper.style.display = sendToAll.checked ? "none" : "block";
  });

  // Character + SMS logic
  message.addEventListener("input", () => {
    const text = message.value;
    charCount.textContent = text.length + " chars";

    if (channel.value === "sms") {
      smsInfo.classList.remove("d-none");

      let segments = Math.ceil(text.length / 160) || 1;
      smsSegments.textContent = segments;
    } else {
      smsInfo.classList.add("d-none");
    }

    updatePreview();
  });

  // Channel change
  channel.addEventListener("change", () => {
    filterUsers();
    updatePreview();
  });

  // Filter users based on channel
  function filterUsers() {
    const selectedChannel = channel.value;

    userSelect.clearOptions();

    const options = document.querySelectorAll("#userSelect option");

    options.forEach(opt => {
      const hasEmail = opt.dataset.email;
      const hasPhone = opt.dataset.phone;

      if (
        (selectedChannel === "email" && hasEmail) ||
        ((selectedChannel === "sms" || selectedChannel === "whatsapp") && hasPhone) ||
        selectedChannel === ""
      ) {
        userSelect.addOption({
          value: opt.value,
          text: opt.text
        });
      }
    });

    userSelect.refreshOptions(false);
  }

  // Preview renderer
  function updatePreview() {
    const text = message.value || "";
    const ch = channel.value;

    if (!text) {
      previewBox.innerHTML = "<em class='text-muted'>Message preview will appear here...</em>";
      return;
    }

    if (ch === "email") {
      previewBox.innerHTML = `
        <strong>Email Preview</strong>
        <hr>
        <p>${text.replace(/\n/g, "<br>")}</p>
      `;
    }

    if (ch === "sms") {
      previewBox.innerHTML = `
        <strong>SMS Preview</strong>
        <hr>
        <p>${text}</p>
      `;
    }

    if (ch === "whatsapp") {
      previewBox.innerHTML = `
        <strong>WhatsApp Preview</strong>
        <hr>
        <div style="background:#e5ddd5;padding:10px;border-radius:10px;">
          <div style="background:white;padding:8px;border-radius:8px;display:inline-block;">
            ${text.replace(/\n/g, "<br>")}
          </div>
        </div>
      `;
    }
  }
</script>