<div class="container-fluid py-3">

  <!-- CHANNEL NAV -->
  <div class="channel-nav">
    <button class="channel-tab active" data-channel="email">📧 Email</button>
    <button class="channel-tab" data-channel="sms">💬 SMS</button>
    <button class="channel-tab" data-channel="whatsapp">🟢 WhatsApp</button>
  </div>

  <div class="layout">

    <!-- CONTACTS -->
    <div class="contacts">

      <input type="text" id="searchUser" placeholder="Search users...">

      <div id="contactList">

        <div class="contact-item" data-id="1" data-name="John Doe">
          <strong>John Doe</strong><br>
          <small>john@gmail.com</small><br>
          <small>+254712345678</small>
        </div>

        <div class="contact-item" data-id="2" data-name="Mary Wanjiku">
          <strong>Mary Wanjiku</strong><br>
          <small>mary@gmail.com</small><br>
          <small>+254798765432</small>
        </div>

      </div>

    </div>

    <!-- CHAT AREA -->
    <div class="chat">

      <!-- HEADER -->
      <div class="chat-header" id="selectedUsersLabel">
        No contact selected
      </div>

      <!-- HISTORY -->
      <div id="messageHistory" class="chat-body">
        <em>Select a contact to view messages</em>
      </div>

      <!-- SELECTED USERS -->
      <div id="selectedUsersContainer"></div>

      <!-- COMPOSER -->
      <div class="composer">

        <textarea id="messageInput" placeholder="Type message..."></textarea>

        <div class="composer-footer">
          <span id="charCount">0 chars</span>
          <span id="smsInfo" style="display:none;">
            | SMS: <span id="smsSegments">1</span>
          </span>

          <button id="clearSelection">Clear</button>
          <button>Send</button>
        </div>

      </div>

    </div>

  </div>
</div>