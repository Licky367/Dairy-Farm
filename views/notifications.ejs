<div class="notifications-page">

  <!-- CHANNEL NAV -->
  <div class="channel-nav">
    <button class="channel-tab active" data-channel="whatsapp">
      <i class="bi bi-whatsapp"></i>
    </button>

    <button class="channel-tab" data-channel="sms">
      <i class="bi bi-chat-dots-fill"></i>
    </button>

    <button class="channel-tab" data-channel="email">
      <i class="bi bi-envelope-fill"></i>
    </button>
  </div>

  <div class="layout">

    <!-- CONTACTS -->
    <div class="contacts">

      <input type="text" id="searchUser" placeholder="Search conversations...">

      <div id="contactList">

        <% users.forEach(user => { %>
          <div 
            class="contact-item"
            data-id="<%= user._id %>"
            data-name="<%= user.name %>"
          >
            <div class="contact-avatar">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <div class="contact-name"><%= user.name %></div>
          </div>
        <% }) %>

      </div>

    </div>

    <!-- CHAT -->
    <div class="chat">

      <!-- HEADER -->
      <div class="chat-header" id="chatHeader">
        Select a conversation
      </div>

      <!-- MESSAGES -->
      <div id="messageHistory" class="chat-body">
        <em>Select a contact to view messages</em>
      </div>

      <!-- COMPOSER -->
      <form id="sendForm" enctype="multipart/form-data" class="composer">

        <input type="hidden" name="channel" id="channelInput" value="whatsapp">
        <input type="hidden" name="userId" id="userIdInput">

        <!-- EMAIL SUBJECT -->
        <input 
          type="text" 
          id="emailSubject"
          name="subject"
          placeholder="Email subject..."
        >

        <!-- ATTACH -->
        <label class="icon-btn">
          <i class="bi bi-paperclip"></i>
          <input type="file" name="attachment" id="fileInput" hidden>
        </label>

        <!-- MESSAGE -->
        <textarea 
          name="message" 
          id="messageInput"
          placeholder="Type a message..."
          required
        ></textarea>

        <!-- SEND -->
        <button type="submit" class="icon-btn send-btn">
          <i class="bi bi-send-fill"></i>
        </button>

      </form>

    </div>

  </div>

  <!-- FLOAT -->
  <button id="newChatBtn" class="fab">
    <i class="bi bi-plus-lg"></i>
  </button>

  <!-- MODAL -->
  <div id="newChatModal" class="modal">

    <div class="modal-content">

      <h4>Start New Chat</h4>

      <input type="text" id="modalSearch" placeholder="Search contacts...">

      <div class="modal-list">

        <% users.forEach(user => { %>
          <div 
            class="modal-item"
            data-id="<%= user._id %>"
            data-name="<%= user.name %>"
          >
            <%= user.name %>
          </div>
        <% }) %>

      </div>

      <button onclick="closeModal()">Close</button>

    </div>

  </div>

</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
body{overflow:hidden;}

.notifications-page{
height:75vh;
display:flex;
flex-direction:column;
}

/* CHANNEL */
.channel-nav{
display:flex;
gap:10px;
margin-bottom:10px;
}
.channel-tab{
padding:10px;
border:none;
border-radius:8px;
background:#eee;
cursor:pointer;
}
.channel-tab.active{
background:#0b5d1e;
color:#fff;
}

/* LAYOUT */
.layout{
display:flex;
flex:1;
gap:20px;
}

/* CONTACTS */
.contacts{
width:30%;
background:#fff;
border-radius:10px;
overflow-y:auto;
padding:10px;
}

.contact-item{
display:flex;
align-items:center;
gap:10px;
padding:10px;
border-bottom:1px solid #eee;
cursor:pointer;
}

.contact-item:hover{
background:#f5f5f5;
}

.contact-avatar{
width:35px;
height:35px;
border-radius:50%;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-weight:bold;
}

/* CHAT */
.chat{
width:70%;
display:flex;
flex-direction:column;
}

.chat-header{
padding:10px;
background:#fff;
border-radius:10px;
margin-bottom:10px;
font-weight:600;
}

/* MESSAGES */
.chat-body{
flex:1;
overflow-y:auto;
background:#e5ddd5;
padding:10px;
border-radius:10px;
display:flex;
flex-direction:column;
gap:8px;
}

.msg{
max-width:70%;
padding:10px;
border-radius:10px;
font-size:14px;
word-break:break-word;
position:relative;
}

.msg.sent{
margin-left:auto;
background:#dcf8c6;
}

.msg.received{
background:#fff;
}

/* ATTACHMENT */
.msg img{
max-width:180px;
margin-top:5px;
border-radius:8px;
}

/* COMPOSER */
.composer{
display:flex;
align-items:center;
gap:8px;
padding:10px;
background:#fff;
border-radius:10px;
}

textarea{
flex:1;
resize:none;
padding:10px;
border-radius:20px;
border:1px solid #ccc;
}

/* SUBJECT */
#emailSubject{
display:none;
width:150px;
padding:6px;
border-radius:10px;
border:1px solid #ccc;
}

/* ICONS */
.icon-btn{
background:none;
border:none;
font-size:20px;
cursor:pointer;
}

.send-btn{color:#0b5d1e;}

/* FLOAT */
.fab{
position:fixed;
bottom:80px;
right:30px;
width:55px;
height:55px;
border-radius:50%;
background:#0b5d1e;
color:#fff;
border:none;
font-size:24px;
cursor:pointer;
}

/* MODAL */
.modal{
display:none;
position:fixed;
inset:0;
background:rgba(0,0,0,.4);
justify-content:center;
align-items:center;
}

.modal-content{
background:#fff;
padding:20px;
border-radius:10px;
width:300px;
}

.modal-item{
padding:10px;
border-bottom:1px solid #eee;
cursor:pointer;
}
</style>

<script>
let currentChannel = "whatsapp";
let currentChat = null;

const tabs = document.querySelectorAll(".channel-tab");
const contacts = document.querySelectorAll(".contact-item");
const history = document.getElementById("messageHistory");
const header = document.getElementById("chatHeader");
const userInput = document.getElementById("userIdInput");
const emailSubject = document.getElementById("emailSubject");
const modal = document.getElementById("newChatModal");

/* CHANNEL SWITCH */
tabs.forEach(tab=>{
  tab.onclick=()=>{
    tabs.forEach(t=>t.classList.remove("active"));
    tab.classList.add("active");

    currentChannel = tab.dataset.channel;
    document.getElementById("channelInput").value = currentChannel;

    emailSubject.style.display = currentChannel === "email" ? "block" : "none";

    loadMessages();
  };
});

/* OPEN CHAT */
contacts.forEach(c=>{
  c.onclick=()=>{
    currentChat = c.dataset.id;
    userInput.value = currentChat;
    header.innerText = c.dataset.name;
    loadMessages();
  };
});

/* LOAD MESSAGES */
function loadMessages(){
  if(!currentChat) return;

  history.innerHTML = "<em>Loading...</em>";

  setTimeout(()=>{
    history.innerHTML = `
      <div class="msg received">Hello 👋</div>
      <div class="msg sent">Hi there</div>
    `;
  },300);
}

/* SEND MESSAGE */
document.getElementById("sendForm").onsubmit = function(e){
  e.preventDefault();

  const text = messageInput.value;
  const file = fileInput.files[0];

  if(!text || !currentChat) return;

  const msg = document.createElement("div");
  msg.className = "msg sent";
  msg.innerText = text;

  if(file){
    if(file.type.startsWith("image/")){
      const img = document.createElement("img");
      img.src = URL.createObjectURL(file);
      msg.appendChild(img);
    } else {
      const fileTag = document.createElement("div");
      fileTag.innerText = "📎 " + file.name;
      msg.appendChild(fileTag);
    }
  }

  history.appendChild(msg);
  history.scrollTop = history.scrollHeight;

  this.reset();
  emailSubject.value = "";
  emailSubject.style.display = currentChannel === "email" ? "block" : "none";
};

/* NEW CHAT */
document.getElementById("newChatBtn").onclick = ()=>{
  modal.style.display="flex";
};

function closeModal(){
  modal.style.display="none";
}

/* SEARCH */
document.getElementById("searchUser").oninput = function(){
  const val = this.value.toLowerCase();
  contacts.forEach(c=>{
    c.style.display = c.dataset.name.toLowerCase().includes(val) ? "flex" : "none";
  });
};
</script>