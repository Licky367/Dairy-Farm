<style>
.container{
max-width:500px;
margin:40px auto;
padding:20px;
}

.card{
background:#fff;
border-radius:14px;
padding:20px;
box-shadow:0 6px 18px rgba(0,0,0,0.06);
border:1px solid #eee;
}

h2{
margin-bottom:20px;
color:#0b5d1e;
text-align:center;
}

.field{
margin-bottom:15px;
}

label{
display:block;
font-size:14px;
font-weight:bold;
margin-bottom:5px;
color:#444;
}

input,
select{
width:100%;
padding:12px;
border-radius:8px;
border:1px solid #ccc;
}

small{
font-size:12px;
color:#777;
}

button{
width:100%;
padding:12px;
background:#0b5d1e;
color:#fff;
border:none;
border-radius:8px;
font-weight:bold;
cursor:pointer;
}
</style>

<div class="container">

<div class="card">

<h2>Create New Category</h2>

<form method="POST" action="/category/create">

<div class="field">
<label>Major Category</label>

<select id="majorCategorySelect">
<option value="">Choose existing major category</option>

<% if (majorCategories && majorCategories.length > 0) { %>
    <% majorCategories.forEach(item => { %>
        <option value="<%= item %>"><%= item %></option>
    <% }) %>
<% } %>

<option value="custom">+ Type New Major Category</option>
</select>

<input 
type="text" 
name="majorCategory"
id="majorCategoryInput"
placeholder="Select above or type new major category"
required
style="margin-top:10px;"
>

<small>Select an existing major category or type a new one.</small>

</div>

<div class="field">
<label>Enter Sub-category Name</label>
<input 
type="text" 
name="category" 
placeholder="e.g. Cooking Oil, Rice, Phone Charger" 
required
>
</div>

<div class="field">
<label>Initial Package Units</label>
<input 
type="number" 
name="packageUnits" 
placeholder="e.g. 12" 
min="1"
required
>
<small>This represents the first stock batch for this category.</small>
</div>

<div class="field">
<label>Package Buying Price (BP)</label>
<input 
type="number" 
name="BP" 
placeholder="e.g. 2500" 
min="1"
required
>
<small>This is the total price for the entire batch, not per unit.</small>
</div>

<button type="submit">Create Category</button>

</form>

</div>

</div>

<script>
const select = document.getElementById("majorCategorySelect");
const input = document.getElementById("majorCategoryInput");

select.addEventListener("change", function () {

if(this.value === "custom"){
input.value = "";
input.focus();
}else{
input.value = this.value;
}

});
</script>