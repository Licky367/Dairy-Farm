<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Payment</title>

<style>
body{
margin:0;
font-family:Arial;
background:#f4f6f8;
}

.header{
background:#0b5d1e;
color:#fff;
padding:20px;
text-align:center;
font-size:20px;
font-weight:bold;
}

.container{
max-width:900px;
margin:30px auto;
background:#fff;
padding:20px;
border-radius:12px;
}

.card{
padding:15px;
border:1px solid #eee;
border-radius:10px;
margin-bottom:15px;
}

label{
font-weight:bold;
display:block;
margin-top:10px;
}

select,input{
width:100%;
padding:10px;
margin-top:5px;
border-radius:8px;
border:1px solid #ccc;
}

button{
background:#0b5d1e;
color:#fff;
border:none;
padding:12px;
border-radius:8px;
cursor:pointer;
margin-top:15px;
width:100%;
}

.amount{
margin-top:10px;
padding:12px;
background:#f1f1f1;
border-radius:8px;
font-weight:bold;
color:#0b5d1e;
}
</style>
</head>

<body>

<div class="header">Payment</div>

<div class="container">

<!-- ================= SINGLE ORDER MODE ================= -->
<% if (order) { %>

<div class="card">
<h3>Order Payment</h3>

<p><b>Order ID:</b> <%= order._id %></p>
<p><b>Total:</b> KES <%= order.totalAmount %></p>
<p><b>Deposit Paid:</b> KES <%= order.depositAmountPaid %></p>
<p><b>Arrears:</b> KES <%= order.arrearAmount %></p>
</div>

<form action="/payment/initiate" method="POST">

<input type="hidden" name="orderId" value="<%= order._id %>">

<label>Payment Type</label>

<select name="paymentType" id="paymentType" onchange="updateAmount()" required>

<option value="">Select</option>
<option value="paid">Pay Full</option>

<% if (order.depositAmountPaid < order.depositAmount) { %>
<option value="depositPaid">Pay Deposit</option>
<% } %>

<option value="arrearAmount">Pay Arrears</option>

</select>

<div class="amount">
Amount: KES <span id="amountDisplay">0</span>
</div>

<button type="submit">Proceed (M-Pesa)</button>

</form>

<% } %>


<!-- ================= BULK MODE ================= -->
<% if (!order && totalArrears !== undefined) { %>

<div class="card">
<h3>Pay All Arrears</h3>
<p><b>Total Arrears:</b> KES <%= totalArrears %></p>
</div>

<form action="/payment/initiate" method="POST">

<input type="hidden" name="paymentType" value="payArrears">

<button type="submit">
Pay All Arrears
</button>

</form>

<% } %>

</div>

<script>

function updateAmount(){

const type = document.getElementById("paymentType").value;

const total = <%= order ? order.totalAmount : 0 %>;
const deposit = <%= order ? order.depositAmount : 0 %>;
const arrear = <%= order ? order.arrearAmount : 0 %>;

let amount = 0;

if(type === "paid") amount = total;
else if(type === "depositPaid") amount = deposit;
else if(type === "arrearAmount") amount = arrear;

document.getElementById("amountDisplay").innerText = amount;

}

</script>

</body>
</html>