<style>
.page-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

/* CART ITEM */
.card{
background:#f8faf8;
padding:18px;
border-radius:14px;
margin-top:12px;
border:1px solid #e6e6e6;
}

.card h3{margin-bottom:8px;}

.price-line{
color:#666;
margin-bottom:10px;
}

/* QTY */
.qty-controls{
display:flex;
align-items:center;
gap:10px;
margin:10px 0;
}

.qty-controls button{
width:36px;height:36px;
border:none;border-radius:8px;
background:#0b5d1e;color:#fff;
cursor:pointer;font-size:18px;
}

.qty-controls input{
width:60px;
text-align:center;
padding:8px;
border:1px solid #ddd;
border-radius:8px;
}

/* REMOVE */
.remove-btn{
background:#b42318;
color:#fff;
border:none;
padding:8px 12px;
border-radius:8px;
cursor:pointer;
font-size:13px;
margin-top:8px;
}

/* TOTAL */
.total{
margin-top:20px;
font-size:22px;
color:#0b5d1e;
font-weight:bold;
}

/* CHECKOUT */
.btn{
margin-top:18px;
background:#0b5d1e;
color:#fff;
border:none;
padding:14px 18px;
border-radius:10px;
cursor:pointer;
font-size:15px;
width:100%;
}

.btn:disabled{
background:#999;
cursor:not-allowed;
}

/* WARNING */
.warning{
color:#b42318;
margin-top:10px;
font-size:14px;
display:none;
}
</style>


<div class="page-box">

<h2>Your Cart</h2>

<% if (!cart || cart.length === 0) { %>

<p style="color:#777;margin-top:15px;">Cart is empty</p>

<% } else { %>

<% let total = 0; %>
<% let hasStockIssue = false; %>

<% cart.forEach(item => { 
const stock = item.itemsAvailable || 0;

if(item.quantity > stock){
hasStockIssue = true;
}
total += item.cost * item.quantity;
%>

<div class="card" data-id="<%= item.id %>" data-stock="<%= stock %>">

<h3><%= item.name %></h3>

<p class="price-line">
KES <%= item.cost.toLocaleString() %>
</p>

<div class="qty-controls">

<button type="button" onclick="changeQty(this,-1)">−</button>

<input type="number"
value="<%= item.quantity %>"
min="1"
max="<%= stock %>"
readonly>

<button type="button" onclick="changeQty(this,1)">+</button>

</div>

<small style="color:gray;">
Available: <%= stock %>
</small>

<button class="remove-btn" onclick="removeItem(this)">
Remove
</button>

</div>

<% }) %>

<div class="total">
Total: KES <span id="total"><%= total.toLocaleString() %></span>
</div>

<div class="warning" id="warning">
⚠ Some items exceed available stock. Adjust quantities before checkout.
</div>

<button class="btn" id="checkoutBtn" <%= hasStockIssue ? "disabled" : "" %>>
Proceed to Checkout
</button>

<% } %>

</div>


<% script = `
<script>

/* QUANTITY UPDATE */
function changeQty(btn, change){
const card = btn.closest(".card");
const input = card.querySelector("input");
const stock = parseInt(card.dataset.stock);

let value = parseInt(input.value);

value += change;

if(value < 1) value = 1;
if(value > stock) value = stock;

input.value = value;

updateCart();
}

/* REMOVE ITEM */
function removeItem(btn){
const card = btn.closest(".card");
card.remove();
updateCart();
}

/* UPDATE TOTAL + VALIDATION */
function updateCart(){

let total = 0;
let hasIssue = false;

document.querySelectorAll(".card").forEach(card => {

const priceText = card.querySelector(".price-line").innerText;
const price = parseInt(priceText.replace(/[^\\d]/g,''));
const qty = parseInt(card.querySelector("input").value);
const stock = parseInt(card.dataset.stock);

if(qty > stock){
hasIssue = true;
}

total += price * qty;
});

document.getElementById("total").innerText = total.toLocaleString();

const warning = document.getElementById("warning");
const btn = document.getElementById("checkoutBtn");

if(hasIssue){
warning.style.display = "block";
btn.disabled = true;
}else{
warning.style.display = "none";
btn.disabled = false;
}
}

updateCart();

</script>
` %>