<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All Orders</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}

body{background:#f4f6f8;min-height:100vh;}

.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;z-index:1000;
}

.main{padding:110px 25px 80px;}

.card{
background:#fff;padding:20px;border-radius:14px;
box-shadow:0 8px 18px rgba(0,0,0,.04);
margin-bottom:15px;border:1px solid #eee;
}

.card p{margin-bottom:8px;}

button{
padding:8px 14px;border:none;border-radius:8px;
background:#0b5d1e;color:#fff;cursor:pointer;
margin-right:5px;
}

.empty{text-align:center;padding:20px;color:#777;}

.filters{
background:#fff;
padding:15px;
border-radius:12px;
margin-bottom:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

.filters select,.filters input{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}

.popup{
position:fixed;top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,.4);
display:none;
align-items:center;justify-content:center;
z-index:2000;
}

.popup-box{
background:#fff;padding:25px;border-radius:12px;
width:320px;text-align:center;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="main">

<h2 style="margin-bottom:15px;">All Orders</h2>

<!-- FILTERS -->
<form method="GET" action="/admin/orders" class="filters">

  <select name="deliveryStatus">
    <option value="">All Delivery Status</option>
    <option value="delivered" <%= query.deliveryStatus==='delivered'?'selected':'' %>>Delivered</option>
    <option value="undelivered" <%= query.deliveryStatus==='undelivered'?'selected':'' %>>Undelivered</option>
  </select>

  <select name="month">
    <option value="">Month</option>
    <% for(let i=1;i<=12;i++){ %>
      <option value="<%= i %>" <%= query.month==i?'selected':'' %>><%= i %></option>
    <% } %>
  </select>

  <input type="number" name="year" placeholder="Year" value="<%= query.year || '' %>">

  <button type="submit">Filter</button>

</form>

<% if (orders && orders.length > 0) { %>

  <% orders.forEach(order => { 
    let amountToPay = order.status === "depositPaid"
      ? order.arrearAmount
      : order.totalAmount;
  %>

    <div class="card">

      <p><b>Order ID:</b> <%= order._id %></p>

      <p><b>Status:</b> 
        <% if(order.manualPayment){ %>
          <span style="color:green;">paid(cash)</span>
        <% } else { %>
          <span style="color:orange;"><%= order.status %></span>
        <% } %>
      </p>

      <p><b>Delivery:</b> 
        <% if(order.delivered){ %>
          <span style="color:green;">Delivered</span>
        <% } else { %>
          <span style="color:red;">Undelivered</span>
        <% } %>
      </p>

      <p><b>Total:</b> KES <%= order.totalAmount %></p>

      <p><b>Ordered At:</b> 
        <%= new Date(order.orderedAt || order.createdAt).toLocaleString() %>
      </p>

      <% if(order.manualPayment){ %>
        <p style="color:green;">
          Paid by <b><%= order.manualPayment.adminName %></b><br>
          Amount: KES <%= order.manualPayment.amount %><br>
          Time: <%= new Date(order.manualPayment.paidAt).toLocaleString() %>
        </p>
      <% } %>

      <!-- ACTION BUTTONS -->

      <% if(!order.manualPayment){ %>
        <button onclick="openPayPopup('<%= order._id %>', <%= amountToPay %>)">
          Mark as Paid (Cash)
        </button>
      <% } %>

      <% if(!order.delivered){ %>
        <button onclick="openDeliveryPopup('<%= order._id %>')">
          Mark as Delivered
        </button>
      <% } else { %>
        <p style="color:green;font-weight:bold;">Already Delivered</p>
      <% } %>

    </div>

  <% }) %>

<% } else { %>

  <p class="empty">No orders found</p>

<% } %>

</div>

<!-- PAYMENT POPUP -->
<div class="popup" id="payPopup">
  <div class="popup-box">

    <h3>Confirm Payment</h3>
    <p id="amountText"></p>

    <form method="POST" id="payForm">
      <button type="submit">Confirm</button>
      <br><br>
      <button type="button" onclick="closePopups()">Cancel</button>
    </form>

  </div>
</div>

<!-- DELIVERY POPUP -->
<div class="popup" id="deliveryPopup">
  <div class="popup-box">

    <h3>Confirm Delivery</h3>
    <p>Mark this order as delivered?</p>

    <form method="POST" id="deliveryForm">
      <button type="submit">Yes, Confirm</button>
      <br><br>
      <button type="button" onclick="closePopups()">Cancel</button>
    </form>

  </div>
</div>

<script>
function openPayPopup(orderId, amount){
  document.getElementById("payPopup").style.display = "flex";
  document.getElementById("payForm").action = "/admin/orders/" + orderId + "/pay";
  document.getElementById("amountText").innerText = "Amount: KES " + amount;
}

function openDeliveryPopup(orderId){
  document.getElementById("deliveryPopup").style.display = "flex";
  document.getElementById("deliveryForm").action = "/admin/orders/" + orderId + "/deliver";
}

function closePopups(){
  document.getElementById("payPopup").style.display = "none";
  document.getElementById("deliveryPopup").style.display = "none";
}
</script>

</body>
</html>