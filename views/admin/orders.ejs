<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All Orders</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}

body{background:#f4f6f8;min-height:100vh;}

.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;z-index:1000;
}

.main{padding:110px 25px 80px;}

.card{
background:#fff;padding:18px;border-radius:14px;
box-shadow:0 8px 18px rgba(0,0,0,.04);
margin-bottom:15px;border:1px solid #eee;
}

.section-title{
font-weight:bold;
margin-top:10px;
color:#0b5d1e;
}

.card p{margin-bottom:6px;}

button{
padding:8px 14px;border:none;border-radius:8px;
background:#0b5d1e;color:#fff;cursor:pointer;
margin-top:10px;
}

.empty{text-align:center;padding:20px;color:#777;}

.filters{
background:#fff;
padding:15px;
border-radius:12px;
margin-bottom:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

.filters select,.filters input{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="main">

<h2 style="margin-bottom:15px;">All Orders</h2>

<!-- FILTERS -->
<form method="GET" action="/admin/orders" class="filters">

  <select name="deliveryStatus">
    <option value="">All Delivery Status</option>
    <option value="delivered" <%= query.deliveryStatus==='delivered'?'selected':'' %>>Delivered</option>
    <option value="undelivered" <%= query.deliveryStatus==='undelivered'?'selected':'' %>>Undelivered</option>
  </select>

  <select name="month">
    <option value="">Month</option>
    <% for(let i=1;i<=12;i++){ %>
      <option value="<%= i %>" <%= query.month==i?'selected':'' %>><%= i %></option>
    <% } %>
  </select>

  <input type="number" name="year" placeholder="Year" value="<%= query.year || '' %>">

  <button type="submit">Filter</button>

</form>

<% if (orders && orders.length > 0) { %>

  <% orders.forEach(order => { %>

    <div class="card">

      <p><b>Order ID:</b> <%= order._id %></p>

      <p><b>Customer:</b> <%= order.customerName || "N/A" %></p>

      <p><b>Phone:</b> <%= order.customerPhone || "N/A" %></p>

      <p><b>Total:</b> KES <%= order.totalAmount %></p>

      <p><b>Status:</b>
        <% if(order.manualPayment){ %>
          <span style="color:green;">paid (cash)</span>
        <% } else { %>
          <span style="color:orange;"><%= order.status %></span>
        <% } %>
      </p>

      <p><b>Delivery Status:</b>
        <% if(order.delivered){ %>
          <span style="color:green;">Delivered</span>
        <% } else { %>
          <span style="color:red;">Undelivered</span>
        <% } %>
      </p>

      <!-- DELIVERY DATE -->
      <p><b>Delivery Date:</b>
        <%= order.deliveryDate ? new Date(order.deliveryDate).toLocaleString() : "Not set" %>
      </p>

      <!-- GPS LOCATION -->
      <p><b>GPS Location:</b>
        <% if(order.locationUrl){ %>
          <a href="<%= order.locationUrl %>" target="_blank">Open Map</a>
        <% } else if(order.gpsLocation){ %>
          <%= order.gpsLocation %>
        <% } else { %>
          N/A
        <% } %>
      </p>

      <p><b>Ordered At:</b>
        <%= new Date(order.orderedAt || order.createdAt).toLocaleString() %>
      </p>

      <button onclick="window.location.href='/admin/orders/<%= order._id %>'">
        View Details
      </button>

    </div>

  <% }) %>

<% } else { %>

  <p class="empty">No orders found</p>

<% } %>

</div>

</body>
</html>