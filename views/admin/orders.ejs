<%- include("partials/layout") %>

<h2>All Orders</h2>

<% orders.forEach(order => { %>

<div class="card" style="margin-bottom:10px;">
    <p><b>Order ID:</b> <%= order._id %></p>
    <p><b>Status:</b> <%= order.status %></p>
    <p><b>Total:</b> KES <%= order.totalAmount %></p>
</div>

<% }) %>

</div></body></html>