<% layout('layout', { title: 'Create Product' }) %>

<style>
/* (UNCHANGED STYLES - KEPT AS IS) */

.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
}

.form-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
max-width:1000px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:15px;
}

.field{
display:flex;
flex-direction:column;
gap:7px;
}

label{
font-size:14px;
font-weight:bold;
color:#444;
}

input,
textarea,
select{
width:100%;
padding:14px;
border:1px solid #ddd;
border-radius:10px;
outline:none;
font-size:15px;
background:#fff;
}

input:focus,
textarea:focus,
select:focus{
border-color:#0b5d1e;
}

textarea{
resize:vertical;
min-height:130px;
}

.preview-box{
margin-top:10px;
padding:14px;
background:#f8f8f8;
border-radius:12px;
font-size:14px;
color:#444;
line-height:1.7;
}

.actions{
margin-top:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

button,
.btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:10px;
cursor:pointer;
font-size:15px;
text-decoration:none;
display:inline-block;
}

.btn-secondary{
background:#1565c0;
}

.error-box{
background:#ffe5e5;
color:#b30000;
padding:12px;
border-radius:10px;
margin-bottom:15px;
}
</style>

<div class="topbar">
<a href="/admin/products" class="btn btn-secondary">
Back to Products
</a>
</div>

<div class="form-box">

<% if (error) { %>
  <div class="error-box">
    <%= error %>
  </div>
<% } %>

<form action="/admin/products/create" method="POST" enctype="multipart/form-data" onsubmit="return validateStock()">

<div class="grid">

<h2>Create Product</h2>

<div class="field">
<label>Product ID</label>
<input name="id" required>
</div>

<div class="field">
<label>Product Name</label>
<input name="name" required>
</div>

<!-- ================= 🔥 NEW: MAJOR CATEGORY ================= -->
<div class="field">
<label>Major Category</label>
<select name="majorCategory" id="majorCategorySelect" required>
<option value="">Select Major Category</option>

<% majorCategories.forEach(mc => { %>
<option value="<%= mc %>">
<%= mc %>
</option>
<% }) %>

</select>
</div>

<!-- ================= CATEGORY ================= -->
<div class="field">
<label>Category</label>
<select name="category" id="categorySelect" required>
<option value="">Select Category</option>

<% categories.forEach(cat => { %>
<option 
value="<%= cat.category %>" 
data-currentunits="<%= cat.currentUnits %>">
<%= cat.category %> (Available: <%= cat.currentUnits %>)
</option>
<% }) %>

</select>
</div>

<div class="field">
<label>Product Units (per item)</label>
<input type="number" name="productUnits" id="productUnits" min="1" required oninput="updatePreview()">
</div>

<div class="field">
<label>No. of Products to Create</label>
<input type="number" name="itemsAvailable" id="itemsAvailable" min="0" required oninput="updatePreview()">
</div>

<div class="field">
<label>Selling Price (KES)</label>
<input type="number" name="cost" id="cost" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Product Deposit Percentage</label>
<input type="number" name="depositPercentage" id="depositPercentage" min="0" max="100" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Estimated Buying Price (KES)</label>
<input type="number" id="purchasePrice" readonly placeholder="Auto estimated">
</div>

<div class="field">
<label>Product Image</label>
<input type="file" name="image">
</div>

</div>

<div class="field" style="margin-top:15px;">
<label>Description</label>
<textarea name="description" required></textarea>
</div>

<div class="preview-box">
<b>Units Needed:</b> <span id="stockNeeded">0</span><br>
<b>Available Units:</b> <span id="availableStock">0</span><br><br>

Deposit: <b><span id="depositPreview">0</span>%</b><br>
Estimated Deposit Amount: <b>KES <span id="depositAmount">0</span></b>
</div>

<div class="actions">
<button type="submit">Create Product</button>

<a href="/admin/products" class="btn btn-secondary">
Cancel
</a>
</div>

</form>

</div>

<script>

/* ================= STOCK PREVIEW ================= */
function updatePreview(){
    const select = document.getElementById("categorySelect");
    const option = select.options[select.selectedIndex];

    const currentUnits = Number(option?.getAttribute("data-currentunits")) || 0;
    const items = Number(document.getElementById("itemsAvailable").value) || 0;
    const units = Number(document.getElementById("productUnits").value) || 0;

    const needed = items * units;

    document.getElementById("stockNeeded").innerText = needed;
    document.getElementById("availableStock").innerText = currentUnits;

    document.getElementById("purchasePrice").value = needed;
}

/* ================= VALIDATION ================= */
function validateStock(){
    const select = document.getElementById("categorySelect");
    const option = select.options[select.selectedIndex];

    const currentUnits = Number(option?.getAttribute("data-currentunits")) || 0;
    const items = Number(document.getElementById("itemsAvailable").value) || 0;
    const units = Number(document.getElementById("productUnits").value) || 0;

    const needed = items * units;

    if(needed > currentUnits){
        alert("Not enough stock in selected category");
        return false;
    }

    return true;
}

/* ================= DEPOSIT ================= */
function calculateDeposit(){
    let cost = Number(document.getElementById("cost").value) || 0;
    let percent = Number(document.getElementById("depositPercentage").value) || 0;

    let total = (cost * percent) / 100;

    document.getElementById("depositAmount").innerText =
    total.toLocaleString();

    document.getElementById("depositPreview").innerText =
    percent;
}

</script>