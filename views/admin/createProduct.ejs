<% layout('layout', { title: 'Create Product' }) %>

<style>
.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
}

.form-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
max-width:1000px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:15px;
}

.field{
display:flex;
flex-direction:column;
gap:7px;
}

label{
font-size:14px;
font-weight:bold;
color:#444;
}

input,
textarea,
select{
width:100%;
padding:14px;
border:1px solid #ddd;
border-radius:10px;
outline:none;
font-size:15px;
background:#fff;
}

input:focus,
textarea:focus,
select:focus{
border-color:#0b5d1e;
}

textarea{
resize:vertical;
min-height:130px;
}

.preview-box{
margin-top:10px;
padding:14px;
background:#f8f8f8;
border-radius:12px;
font-size:14px;
color:#444;
line-height:1.7;
}

.actions{
margin-top:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

button,
.btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:10px;
cursor:pointer;
font-size:15px;
text-decoration:none;
display:inline-block;
}

.btn-secondary{
background:#1565c0;
}
</style>

<div class="topbar">
<h2>Create Product</h2>

<a href="/admin/products" class="btn btn-secondary">
Back to Products
</a>
</div>

<div class="form-box">

<form action="/admin/products/create" method="POST" enctype="multipart/form-data">

<div class="grid">

<div class="field">
<label>Product ID</label>
<input name="id" placeholder="Product ID" required>
</div>

<div class="field">
<label>Product Name</label>
<input name="name" placeholder="Product Name" required>
</div>

<div class="field">
<label>Category</label>
<input name="category" placeholder="Category" required>
</div>

<div class="field">
<label>Selling Price (KES)</label>
<input type="number" name="cost" id="cost" placeholder="Cost" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Purchase Price (KES)</label>
<input type="number" name="purchasePrice" placeholder="Buying Price" min="0" required>
</div>

<div class="field">
<label>Deposit Percentage</label>
<input type="number" name="depositPercentage" id="depositPercentage" placeholder="Deposit %" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Items Available</label>
<input type="number" name="itemsAvailable" placeholder="Stock Quantity" min="0" required>
</div>

<div class="field">
<label>Product Image</label>
<input type="file" name="image">
</div>

</div>

<div class="field" style="margin-top:15px;">
<label>Description</label>
<textarea name="description" placeholder="Description" required></textarea>
</div>

<div class="preview-box">
Deposit Amount: <b><span id="depositPreview">0</span>%</b><br>
Estimated Deposit Amount: <b>KES <span id="depositAmount">0</span></b>
</div>

<div class="actions">
<button type="submit">Create Product</button>

<a href="/admin/products" class="btn btn-secondary">
Cancel
</a>
</div>

</form>

</div>

<script>
function calculateDeposit(){
let cost = Number(document.getElementById("cost").value) || 0;
let percent = Number(document.getElementById("depositPercentage").value) || 0;

let total = (cost * percent) / 100;

document.getElementById("depositAmount").innerText =
total.toLocaleString();

document.getElementById("depositPreview").innerText =
percent;
}
</script>