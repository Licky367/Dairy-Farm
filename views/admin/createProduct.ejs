<%- include("../partials/layout", { title: "Create Product" }) %>

<div class="topbar">
<h2>Create Product</h2>
</div>

<div class="table-box">

<form action="/admin/products/create" method="POST" enctype="multipart/form-data">

<div style="display:grid; gap:15px;">

<input name="id" placeholder="Product ID" required>

<input name="name" placeholder="Product Name" required>

<input name="category" placeholder="Category" required>

<input type="number" name="cost" placeholder="Cost (KES)" required>

<input type="number" name="depositPercentage" placeholder="Deposit %" required>

<textarea name="description" placeholder="Description" rows="5" required></textarea>

<input type="file" name="image">

<button type="submit" style="
background:#0b5d1e;
color:white;
padding:12px;
border:none;
border-radius:10px;
cursor:pointer;
font-size:15px;
">
Create Product
</button>

</div>

</form>

</div>