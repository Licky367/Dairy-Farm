<% layout('layout', { title: 'Create Product' }) %>

<div class="form-box">

<% if (error) { %>
  <div class="error-box"><%= error %></div>
<% } %>

<form action="/admin/products/create" method="POST" enctype="multipart/form-data" onsubmit="return validateStock()">

<div class="grid">

<h2>Create Product</h2>

<!-- PRODUCT ID -->
<div class="field">
<label>Product ID</label>
<input name="id" required>
</div>

<!-- PRODUCT NAME -->
<div class="field">
<label>Product Name</label>
<input name="name" required>
</div>

<!-- ================= MAJOR CATEGORY ================= -->
<div class="field">
<label>Major Category</label>
<select name="majorCategory" id="majorCategorySelect" required>
<option value="">Select Major Category</option>

<% groupedCategories.forEach(group => { %>
<option value="<%= group.majorCategory %>">
<%= group.majorCategory %>
</option>
<% }) %>

</select>
</div>

<!-- ================= CATEGORY (DEPENDENT) ================= -->
<div class="field">
<label>Category</label>
<select name="category" id="categorySelect" required disabled>
<option value="">Select Major Category First</option>
</select>
</div>

<!-- PRODUCT UNITS -->
<div class="field">
<label>Product Units (per item)</label>
<input type="number" name="productUnits" id="productUnits" min="1" required oninput="updatePreview()">
</div>

<!-- ITEMS -->
<div class="field">
<label>No. of Products to Create</label>
<input type="number" name="itemsAvailable" id="itemsAvailable" min="0" required oninput="updatePreview()">
</div>

<!-- COST -->
<div class="field">
<label>Selling Price (KES)</label>
<input type="number" name="cost" id="cost" required oninput="calculateDeposit()">
</div>

<!-- DEPOSIT -->
<div class="field">
<label>Deposit Percentage</label>
<input type="number" name="depositPercentage" id="depositPercentage" min="0" max="100" required oninput="calculateDeposit()">
</div>

<!-- PURCHASE PRICE -->
<div class="field">
<label>Estimated Buying Price (KES)</label>
<input type="number" id="purchasePrice" readonly>
</div>

<!-- IMAGE -->
<div class="field">
<label>Product Image</label>
<input type="file" name="image">
</div>

</div>

<!-- DESCRIPTION -->
<div class="field" style="margin-top:15px;">
<label>Description</label>
<textarea name="description" required></textarea>
</div>

<!-- PREVIEW -->
<div class="preview-box">
<b>Units Needed:</b> <span id="stockNeeded">0</span><br>
<b>Available Units:</b> <span id="availableStock">0</span><br><br>

Deposit: <b><span id="depositPreview">0</span>%</b><br>
Estimated Deposit Amount: <b>KES <span id="depositAmount">0</span></b>
</div>

<div class="actions">
<button type="submit">Create Product</button>
<a href="/admin/products" class="btn btn-secondary">Cancel</a>
</div>

</form>
</div>

<script>

/* ================= DATA FROM BACKEND ================= */
const groupedCategories = <%- JSON.stringify(groupedCategories || []) %>;

/* ================= MAJOR → CATEGORY DEPENDENCY ================= */
const majorSelect = document.getElementById("majorCategorySelect");
const categorySelect = document.getElementById("categorySelect");

majorSelect.addEventListener("change", function () {

    const selectedMajor = this.value;

    categorySelect.innerHTML = "";

    if (!selectedMajor) {
        categorySelect.disabled = true;
        categorySelect.innerHTML = `<option>Select Major Category First</option>`;
        return;
    }

    const group = groupedCategories.find(g => g.majorCategory === selectedMajor);

    if (!group) {
        categorySelect.disabled = true;
        categorySelect.innerHTML = `<option>No categories found</option>`;
        return;
    }

    categorySelect.disabled = false;

    categorySelect.innerHTML = `<option value="">Select Category</option>`;

    group.categories.forEach(cat => {

        const opt = document.createElement("option");
        opt.value = cat.category;
        opt.setAttribute("data-currentunits", cat.currentUnits);
        opt.textContent = `${cat.category} (Available: ${cat.currentUnits})`;

        categorySelect.appendChild(opt);
    });

});


/* ================= STOCK PREVIEW ================= */
function updatePreview(){

    const option = categorySelect.options[categorySelect.selectedIndex];

    const currentUnits = Number(option?.getAttribute("data-currentunits")) || 0;

    const items = Number(document.getElementById("itemsAvailable").value) || 0;
    const units = Number(document.getElementById("productUnits").value) || 0;

    const needed = items * units;

    document.getElementById("stockNeeded").innerText = needed;
    document.getElementById("availableStock").innerText = currentUnits;

    document.getElementById("purchasePrice").value = needed;
}


/* ================= VALIDATION ================= */
function validateStock(){

    const option = categorySelect.options[categorySelect.selectedIndex];

    const currentUnits = Number(option?.getAttribute("data-currentunits")) || 0;

    const items = Number(document.getElementById("itemsAvailable").value) || 0;
    const units = Number(document.getElementById("productUnits").value) || 0;

    const needed = items * units;

    if (needed > currentUnits) {
        alert("Not enough stock in selected category");
        return false;
    }

    return true;
}


/* ================= DEPOSIT ================= */
function calculateDeposit(){

    let cost = Number(document.getElementById("cost").value) || 0;
    let percent = Number(document.getElementById("depositPercentage").value) || 0;

    let total = (cost * percent) / 100;

    document.getElementById("depositAmount").innerText = total.toLocaleString();
    document.getElementById("depositPreview").innerText = percent;
}

</script>