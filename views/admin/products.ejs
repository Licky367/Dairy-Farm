<% layout('layout', { title: 'Manage Products' }) %>

<style>

/* ================= TOP BAR ================= */
.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:12px;
}

.summary{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.badge{
background:#eef7ef;
color:#0b5d1e;
padding:8px 14px;
border-radius:30px;
font-size:13px;
font-weight:bold;
}

.btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:12px 18px;
border-radius:10px;
cursor:pointer;
font-size:14px;
text-decoration:none;
display:inline-block;
}

.btn-danger{background:#b71c1c;}
.btn-secondary{background:#1565c0;}

/* ================= MAJOR CATEGORY ================= */
.major-section{
margin-bottom:50px;
}

.major-title{
font-size:22px;
font-weight:bold;
color:#0b5d1e;
margin:20px 0 15px;
padding:10px;
background:#f7f7f7;
border-radius:10px;
position:sticky;
top:0;
z-index:5;
}

/* ================= CATEGORY SECTION ================= */
.category-section{
margin-bottom:45px;
}

.category-title{
font-size:18px;
margin:10px 0 15px;
color:#333;
padding-left:5px;
position:sticky;
top:60px;
background:#fff;
z-index:4;
}

/* ================= SLIDER ================= */
.slider-wrapper{
position:relative;
}

.products-row{
display:flex;
gap:18px;
overflow-x:auto;
scroll-behavior:smooth;
padding:10px 5px 20px;
scroll-snap-type:x mandatory;
}

.products-row::-webkit-scrollbar{
display:none;
}

.products-row{
scrollbar-width:none;
}

/* ================= CARD ================= */
.card{
background:#fff;
padding:18px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
min-width:280px;
flex:0 0 auto;
scroll-snap-align:start;
transition:.25s ease;
}

.card:hover{
transform:scale(1.03);
}

.card img{
width:100%;
height:180px;
object-fit:cover;
border-radius:12px;
margin-bottom:12px;
background:#eee;
}

.card h3{
margin-bottom:8px;
font-size:18px;
color:#222;
}

.card p{
margin-bottom:6px;
color:#666;
font-size:13px;
}

/* ================= STOCK ================= */
.stock{
margin-top:10px;
display:inline-block;
padding:7px 12px;
border-radius:20px;
font-size:12px;
font-weight:bold;
}

.instock{background:#e8f5e9;color:#0b5d1e;}
.lowstock{background:#fff3cd;color:#8a6d00;}
.outstock{background:#fdecea;color:#b42318;}

/* ================= ACTIONS ================= */
.actions{
display:flex;
gap:10px;
margin-top:14px;
flex-wrap:wrap;
}

/* ================= NAV BUTTONS ================= */
.nav-btn{
position:absolute;
top:40%;
transform:translateY(-50%);
background:rgba(0,0,0,.6);
color:#fff;
border:none;
width:40px;
height:40px;
border-radius:50%;
cursor:pointer;
z-index:10;
display:flex;
align-items:center;
justify-content:center;
font-size:20px;
}

.nav-left{left:-10px;}
.nav-right{right:-10px;}

.nav-btn:hover{
background:rgba(0,0,0,.8);
}

/* ================= EMPTY ================= */
.empty-box{
background:#fff;
padding:30px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
text-align:center;
color:#777;
}

</style>

<!-- ================= TOP BAR ================= -->
<div class="topbar">

<div>
<h2>Manage Products</h2>
</div>

<div class="summary">

<span class="badge">
Total: 
<%= groupedProducts 
    ? groupedProducts.reduce((sum, g) => {
        return sum + g.categories.reduce((s, c) => s + c.products.length, 0);
      }, 0)
    : 0 
%>
</span>

<a href="/admin/products/create" class="btn">
Add Product
</a>

</div>

</div>

<!-- ================= PRODUCTS ================= -->

<% if(groupedProducts && groupedProducts.length > 0){ %>

<% groupedProducts.forEach(major => { %>

<div class="major-section">

<div class="major-title">
<%= major.majorCategory %>
</div>

<% major.categories.forEach(cat => { %>

<div class="category-section">

<div class="category-title">
<%= cat.category %>
</div>

<div class="slider-wrapper">

<button class="nav-btn nav-left" onclick="scrollRow(this, -320)">‹</button>
<button class="nav-btn nav-right" onclick="scrollRow(this, 320)">›</button>

<div class="products-row">

<% cat.products.forEach(product => { %>

<div class="card">

<img src="<%= product.image %>" alt="<%= product.name %>">

<h3><%= product.name %></h3>

<p><b>ID:</b> <%= product.id %></p>
<p><b>Price:</b> KES <%= product.cost %></p>
<p><b>Deposit:</b> <%= product.depositPercentage %>% (KES <%= product.depositAmount %>)</p>
<p><b>Description:</b> <%= product.description || "No description" %></p>

<% const stock = product.itemsAvailable || 0; %>

<% if(stock === 0){ %>
<span class="stock outstock">Out of Stock</span>
<% } else if(stock <= 5){ %>
<span class="stock lowstock">Low Stock: <%= stock %></span>
<% } else { %>
<span class="stock instock">In Stock: <%= stock %></span>
<% } %>

<div class="actions">

<a href="/admin/products/edit/<%= product.id %>" class="btn btn-secondary">
Edit
</a>

<form action="/admin/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this product?')">
<button class="btn btn-danger" type="submit">
Delete
</button>
</form>

</div>

</div>

<% }) %>

</div>

</div>

</div>

<% }) %>

</div>

<% }) %>

<% } else { %>

<div class="empty-box">
<p>No products found.</p>
</div>

<% } %>

<script>
function scrollRow(btn, distance){
const row = btn.parentElement.querySelector(".products-row");
row.scrollBy({ left: distance, behavior: "smooth" });
}
</script>