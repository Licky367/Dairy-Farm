<% layout('layout', { title: 'Manage Products' }) %>

<style>
.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:12px;
}

.summary{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.badge{
background:#eef7ef;
color:#0b5d1e;
padding:8px 14px;
border-radius:30px;
font-size:13px;
font-weight:bold;
}

.btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:12px 18px;
border-radius:10px;
cursor:pointer;
font-size:14px;
text-decoration:none;
display:inline-block;
}

.btn-danger{
background:#b71c1c;
}

.btn-secondary{
background:#1565c0;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:20px;
}

.card{
background:#fff;
padding:20px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
transition:.25s ease;
}

.card:hover{
transform:translateY(-3px);
}

.card img{
width:100%;
height:190px;
object-fit:cover;
border-radius:12px;
margin-bottom:15px;
background:#eee;
}

.card h3{
margin-bottom:10px;
color:#222;
font-size:20px;
}

.card p{
margin-bottom:8px;
color:#666;
font-size:14px;
line-height:1.5;
}

.stock{
margin-top:10px;
display:inline-block;
padding:8px 12px;
border-radius:20px;
font-size:12px;
font-weight:bold;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

.actions{
display:flex;
gap:10px;
margin-top:16px;
flex-wrap:wrap;
}

.empty-box{
background:#fff;
padding:30px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
text-align:center;
color:#777;
}
</style>

<div class="topbar">

<div>
<h2>Manage Products</h2>
</div>

<div class="summary">
<span class="badge">
Total: <%= products ? products.length : 0 %>
</span>

<a href="/admin/products/create" class="btn">
Add Product
</a>
</div>

</div>

<div class="grid">

<% if(products && products.length > 0){ %>

<% products.forEach(product => { %>

<div class="card">

<img src="<%= product.image %>" alt="<%= product.name %>">

<h3><%= product.name %></h3>

<p><b>ID:</b> <%= product.id %></p>

<p><b>Category:</b> <%= product.category %></p>

<p><b>Price:</b> KES <%= product.cost %></p>

<p><b>Deposit:</b> <%= product.depositPercentage %>% (KES <%= product.depositAmount %>)</p>

<p><b>Description:</b> <%= product.description || "No description" %></p>

<% if((product.itemsAvailable || 0) === 0){ %>
<span class="stock outstock">
Out of Stock
</span>

<% } else if((product.itemsAvailable || 0) <= 5){ %>
<span class="stock lowstock">
Low Stock: <%= product.itemsAvailable %> left
</span>

<% } else { %>
<span class="stock instock">
In Stock: <%= product.itemsAvailable %>
</span>
<% } %>

<div class="actions">

<a href="/admin/products/edit/<%= product.id %>" class="btn btn-secondary">
Edit
</a>

<form action="/admin/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this product?')">
<button class="btn btn-danger" type="submit">
Delete
</button>
</form>

</div>

</div>

<% }) %>

<% } else { %>

<div class="empty-box">
<p>No products found.</p>
</div>

<% } %>

</div>