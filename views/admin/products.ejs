<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manage Products</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f8;
min-height:100vh;
color:#222;
}

/* HEADER */
.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
text-align:center;
padding:0 15px;
}

/* TOP MENU */
.topmenu{
position:fixed;
top:70px;
left:0;
right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

.profile-box{
position:relative;
}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.dropdown a:hover{
background:#f7f7f7;
}

.profile-box.active .dropdown{
display:block;
}

/* SIDEBAR */
.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{
left:0;
}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
transition:.3s;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{
display:block;
}

/* MAIN */
.main{
padding:150px 25px 80px;
}

.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:12px;
}

.summary{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.badge{
background:#eef7ef;
color:#0b5d1e;
padding:8px 14px;
border-radius:30px;
font-size:13px;
font-weight:bold;
}

/* BUTTONS */
.btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:12px 18px;
border-radius:10px;
cursor:pointer;
font-size:14px;
text-decoration:none;
display:inline-block;
}

.btn-danger{
background:#b71c1c;
}

.btn-secondary{
background:#1565c0;
}

.btn:hover{
opacity:.92;
}

/* PRODUCT GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:20px;
}

.card{
background:#fff;
padding:20px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
transition:.25s ease;
}

.card:hover{
transform:translateY(-3px);
}

.card img{
width:100%;
height:190px;
object-fit:cover;
border-radius:12px;
margin-bottom:15px;
background:#eee;
}

.card h3{
margin-bottom:10px;
color:#222;
font-size:20px;
}

.card p{
margin-bottom:8px;
color:#666;
font-size:14px;
line-height:1.5;
}

.stock{
margin-top:10px;
display:inline-block;
padding:8px 12px;
border-radius:20px;
font-size:12px;
font-weight:bold;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

.actions{
display:flex;
gap:10px;
margin-top:16px;
flex-wrap:wrap;
}

.empty-box{
background:#fff;
padding:30px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
text-align:center;
color:#777;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
padding:0 10px;
text-align:center;
}

@media(max-width:768px){

.main{
padding:145px 15px 80px;
}

.topbar{
flex-direction:column;
align-items:flex-start;
}

.header{
font-size:18px;
}

.profile-btn{
font-size:13px;
padding:8px 12px;
}

}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="topmenu">

<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
</div>
</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/products/create">Create Product</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<a href="/logout">Logout</a>
</div>

<div class="main">

<div class="topbar">

<div>
<h2>Manage Products</h2>
</div>

<div class="summary">
<span class="badge">
Total: <%= products ? products.length : 0 %>
</span>

<a href="/admin/products/create" class="btn">
Add Product
</a>
</div>

</div>

<div class="grid">

<% if(products && products.length > 0){ %>

<% products.forEach(product => { %>

<div class="card">

<img src="<%= product.image %>" alt="<%= product.name %>">

<h3><%= product.name %></h3>

<p><b>ID:</b> <%= product.id %></p>

<p><b>Category:</b> <%= product.category %></p>

<p><b>Price:</b> KES <%= product.cost %></p>

<p><b>Deposit:</b> <%= product.depositPercentage %>% (KES <%= product.depositAmount %>)</p>

<p><b>Description:</b> <%= product.description || "No description" %></p>

<% if((product.itemsAvailable || 0) === 0){ %>
<span class="stock outstock">
Out of Stock
</span>

<% } else if((product.itemsAvailable || 0) <= 5){ %>
<span class="stock lowstock">
Low Stock: <%= product.itemsAvailable %> left
</span>

<% } else { %>
<span class="stock instock">
In Stock: <%= product.itemsAvailable %>
</span>
<% } %>

<div class="actions">

<a href="/admin/products/edit/<%= product.id %>" class="btn btn-secondary">
Edit
</a>

<form action="/admin/products/delete/<%= product.id %>" method="POST" onsubmit="return confirm('Delete this product?')">
<button class="btn btn-danger" type="submit">
Delete
</button>
</form>

</div>

</div>

<% }) %>

<% } else { %>

<div class="empty-box">
<p>No products found.</p>
</div>

<% } %>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(event){
event.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click",function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});
</script>

</body>
</html>