<% layout('layout', { title: 'Manage Products' }) %>

<style>
.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
}

/* BUTTONS */
.btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:12px 18px;
border-radius:10px;
cursor:pointer;
font-size:14px;
text-decoration:none;
display:inline-block;
}

.btn-danger{
background:#b71c1c;
}

.btn-secondary{
background:#1565c0;
}

/* PRODUCT GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:20px;
max-width:1100px;
margin:auto;
}

.card{
background:#fff;
padding:20px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card img{
width:100%;
height:180px;
object-fit:cover;
border-radius:12px;
margin-bottom:15px;
background:#eee;
}

.card h3{
margin-bottom:10px;
color:#222;
}

.card p{
margin-bottom:8px;
color:#666;
}

.actions{
display:flex;
gap:10px;
margin-top:15px;
flex-wrap:wrap;
}
</style>

<div class="topbar">
<h2>Manage Products</h2>

<a href="/admin/products/create" class="btn">
Add Product
</a>
</div>

<div class="grid">

<% if(products && products.length > 0){ %>

<% products.forEach(product => { %>

<div class="card">

<img src="<%= product.image %>" alt="<%= product.name %>">

<h3><%= product.name %></h3>

<p><b>Category:</b> <%= product.category %></p>

<p><b>Price:</b> KES <%= product.cost %></p>

<div class="actions">

<a href="/admin/products/edit/<%= product.id %>" class="btn btn-secondary">
Edit
</a>

<form action="/admin/products/delete/<%= product.id %>" method="POST">
<button class="btn btn-danger" type="submit">
Delete
</button>
</form>

</div>

</div>

<% }) %>

<% } else { %>

<div class="card" style="max-width:600px;margin:auto;">
<p>No products found.</p>
</div>

<% } %>

</div>