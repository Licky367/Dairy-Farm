<% layout('layout', { title: 'Unpaid Delivered Orders' }) %>

<style>
.container{
max-width:1000px;
margin:auto;
}

h2{
margin-bottom:20px;
color:#0b5d1e;
}

table{
width:100%;
border-collapse:collapse;
background:#fff;
border-radius:10px;
overflow:hidden;
box-shadow:0 8px 20px rgba(0,0,0,.05);
}

th, td{
padding:12px;
border-bottom:1px solid #eee;
text-align:left;
}

th{
background:#0b5d1e;
color:white;
}

a{
color:#0b5d1e;
text-decoration:none;
font-weight:bold;
}

.empty{
text-align:center;
padding:20px;
color:#777;
background:#fff;
border-radius:10px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
}
</style>

<div class="container">

<h2>Delivered but Unpaid Orders</h2>

<% if (orders && orders.length > 0) { %>

<table>
<thead>
<tr>
<th>Order ID</th>
<th>Customer Name</th>
<th>Phone</th>
<th>Arrear Amount (KES)</th>
</tr>
</thead>

<tbody>

<% orders.forEach(order => { %>

<tr>
<td>
<a href="/admin/orders/<%= order._id %>">
<%= order._id %>
</a>
</td>

<td><%= order.customerName || "N/A" %></td>

<td><%= order.customerPhone || "N/A" %></td>

<td><%= Number(order.arrearAmount || 0).toLocaleString() %></td>
</tr>

<% }) %>

</tbody>
</table>

<% } else { %>

<div class="empty">
No unpaid delivered orders found
</div>

<% } %>

</div>