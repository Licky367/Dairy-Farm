<%- include("../partials/layout") %>

<style>
.dashboard-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:30px;
}

.stat-card{
background:white;
padding:25px;
border-radius:14px;
box-shadow:0 5px 20px rgba(0,0,0,.08);
}

.stat-card h3{
font-size:16px;
color:gray;
margin-bottom:10px;
}

.stat-card h1{
font-size:30px;
color:#0b5d1e;
}

.table-card{
background:white;
padding:25px;
border-radius:14px;
box-shadow:0 5px 20px rgba(0,0,0,.08);
overflow-x:auto;
}

table{
width:100%;
border-collapse:collapse;
}

th,td{
padding:14px;
border-bottom:1px solid #eee;
text-align:left;
}

th{
color:#0b5d1e;
}
.quick-links{
display:flex;
gap:15px;
flex-wrap:wrap;
margin-bottom:25px;
}

.quick-links a{
background:#0b5d1e;
color:white;
padding:12px 18px;
border-radius:10px;
text-decoration:none;
}
</style>

<h1 style="margin-bottom:20px;">Admin Dashboard</h1>

<div class="quick-links">
<a href="/admin/products">Products</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/users">Users</a>
<a href="/logout">Logout</a>
</div>

<div class="dashboard-grid">

<div class="stat-card">
<h3>Total Products</h3>
<h1><%= totalProducts %></h1>
</div>

<div class="stat-card">
<h3>Total Orders</h3>
<h1><%= totalOrders %></h1>
</div>

<div class="stat-card">
<h3>Total Users</h3>
<h1><%= totalUsers %></h1>
</div>

<div class="stat-card">
<h3>Total Revenue</h3>
<h1>KES <%= totalRevenue.toLocaleString() %></h1>
</div>

</div>

<div class="table-card">

<h2 style="margin-bottom:15px;">Recent Orders</h2>

<table>

<tr>
<th>Order ID</th>
<th>Status</th>
<th>Total</th>
<th>Date</th>
</tr>

<% recentOrders.forEach(order => { %>

<tr>
<td><%= order._id %></td>
<td><%= order.status %></td>
<td>KES <%= order.totalAmount.toLocaleString() %></td>
<td><%= order.createdAt.toDateString() %></td>
</tr>

<% }) %>

</table>

</div>

</div>
</body>
</html>