<%- include("partials/layout", { title: "Admin Dashboard" }) %>

<div class="topbar">
<h2>Admin Dashboard</h2>

<div>
Welcome, <%= user ? user.name : "" %>
</div>

</div>

<div class="cards">

<div class="card">
<h3>Total Products</h3>
<h1><%= totalProducts || 0 %></h1>
</div>

<div class="card">
<h3>Total Orders</h3>
<h1><%= totalOrders || 0 %></h1>
</div>

<div class="card">
<h3>Total Clients</h3>
<h1><%= totalClients || 0 %></h1>
</div>

<div class="card">
<h3>Revenue</h3>
<h1>KES <%= revenue || 0 %></h1>
</div>

</div>

<div class="table-box">

<h3 style="margin-bottom:20px;">Recent Orders</h3>

<table>

<tr>
<th>Order ID</th>
<th>Client</th>
<th>Amount</th>
<th>Status</th>
</tr>

<% if (recentOrders && recentOrders.length > 0) { %>

<% recentOrders.forEach(order => { %>

<tr>
<td><%= order.id %></td>
<td><%= order.clientName %></td>
<td>KES <%= order.amount %></td>
<td>
<span class="status">
<%= order.status %>
</span>
</td>
</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="4" class="empty">
No recent orders found
</td>
</tr>

<% } %>

</table>

</div>