<% layout('layout', { title: 'Admin Dashboard' }) %>

<style>
.topbar{
background:#fff;padding:20px;border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
display:flex;justify-content:space-between;
align-items:center;gap:15px;margin-bottom:25px;flex-wrap:wrap;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;margin-bottom:25px;
}

.card{
background:#fff;padding:25px;border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card h3{color:#666;margin-bottom:10px;font-size:15px;}
.card h1{color:#0b5d1e;font-size:30px;margin-bottom:6px;}
.card p{font-size:13px;color:#777;}

.filters{
background:#fff;
padding:15px;
border-radius:12px;
margin-bottom:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

.filters select,.filters input{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}

.table-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
overflow:auto;
margin-bottom:25px;
}

.section-title{
margin-bottom:18px;
color:#222;
}

table{
width:100%;
border-collapse:collapse;
min-width:650px;
}

th,td{
padding:14px;
text-align:left;
border-bottom:1px solid #eee;
}

th{
color:#555;
font-size:14px;
background:#fafafa;
}

td{font-size:14px;}

.status{
padding:6px 10px;
border-radius:20px;
font-size:12px;
background:#e8f5e9;
color:#0b5d1e;
font-weight:bold;
display:inline-block;
}

.empty{
padding:20px;
text-align:center;
color:#777;
}
</style>

<div class="topbar">
<div>
<h2>Admin Dashboard</h2>
<small>Welcome, <%= user ? user.name : "Administrator" %></small>
</div>
<div>
<small><%= new Date().toDateString() %></small>
</div>
</div>

<!-- FILTER -->
<form method="GET" action="/admin/dashboard" class="filters">
<select name="month">
<option value="">Month</option>
<% for(let i=1;i<=12;i++){ %>
<option value="<%= i %>" <%= query.month==i?'selected':'' %>><%= i %></option>
<% } %>
</select>

<input type="number" name="year" placeholder="Year" value="<%= query.year || '' %>">

<button type="submit">Filter</button>
</form>

<div class="cards">

<div class="card">
<h3>Total Products</h3>
<h1><%= totalProducts || 0 %></h1>
<p>Registered products</p>
</div>

<div class="card">
<h3>Monthly Orders</h3>
<h1><%= totalOrders || 0 %></h1>
<p>Year Total: <b><%= yearOrders || 0 %></b></p>
</div>

<div class="card">
<h3>Total Clients</h3>
<h1><%= totalClients || 0 %></h1>
<p>Customer accounts</p>
</div>

<div class="card">
<h3>Revenue</h3>
<h1>KES <%= revenue || 0 %></h1>
<p>Year Total: <b>KES <%= yearRevenue || 0 %></b></p>
</div>

<div class="card">
<h3>Items In Stock</h3>
<h1><%= totalItemsAvailable || 0 %></h1>
<p>All available units</p>
</div>

<div class="card">
<h3>Low Stock Products</h3>
<h1><%= lowStockCount || 0 %></h1>
<p>Need restocking soon</p>
</div>

</div>

<div class="table-box">

<h3 class="section-title">Recent Orders</h3>

<table>

<tr>
<th>Order ID</th>
<th>Client</th>
<th>Amount</th>
<th>Status</th>
</tr>

<% if (recentOrders && recentOrders.length > 0) { %>

<% recentOrders.forEach(order => { %>

<tr>
<td><%= order._id %></td>
<td><%= order.customerName %></td>
<td>KES <%= order.totalAmount %></td>
<td><span class="status"><%= order.status %></span></td>
</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="4" class="empty">No recent orders found</td>
</tr>

<% } %>

</table>

</div>