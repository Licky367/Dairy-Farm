<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}
body{background:#f4f6f8;min-height:100vh;color:#222;}

.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;z-index:1000;
padding:0 15px;text-align:center;
}

.topmenu{
position:fixed;top:70px;left:0;right:0;height:60px;
background:#fff;display:flex;align-items:center;
justify-content:space-between;padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);z-index:999;
}

.menu-btn{font-size:28px;cursor:pointer;color:#0b5d1e;font-weight:bold;}

.profile-box{position:relative;}

.profile-btn{
background:#0b5d1e;color:#fff;border:none;
padding:10px 16px;border-radius:30px;
cursor:pointer;font-size:14px;
}

.dropdown{
position:absolute;right:0;top:48px;width:180px;
background:#fff;border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;overflow:hidden;
}

.dropdown a{
display:block;padding:14px;text-decoration:none;
color:#333;border-bottom:1px solid #eee;
}

.dropdown a:hover{background:#f7f7f7;}
.profile-box.active .dropdown{display:block;}

.sidebar{
position:fixed;top:0;left:-280px;width:260px;height:100%;
background:#0b5d1e;padding:140px 20px 20px;
transition:.35s ease;z-index:1200;overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar a{
display:block;color:#fff;text-decoration:none;
padding:14px;margin-bottom:10px;border-radius:10px;
transition:.3s;
}

.sidebar a:hover{background:rgba(255,255,255,.15);}

.overlay{
position:fixed;top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,.35);display:none;z-index:1100;
}

.overlay.active{display:block;}

.main{padding:150px 25px 80px;}

.topbar{
background:#fff;padding:20px;border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
display:flex;justify-content:space-between;
align-items:center;gap:15px;margin-bottom:25px;flex-wrap:wrap;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;margin-bottom:25px;
}

.card{
background:#fff;padding:25px;border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card h3{color:#666;margin-bottom:10px;font-size:15px;}
.card h1{color:#0b5d1e;font-size:30px;margin-bottom:6px;}
.card p{font-size:13px;color:#777;}

.filters{
background:#fff;
padding:15px;
border-radius:12px;
margin-bottom:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

.filters select,.filters input{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
}

.table-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
overflow:auto;
margin-bottom:25px;
}

.section-title{
margin-bottom:18px;
color:#222;
}

table{
width:100%;
border-collapse:collapse;
min-width:650px;
}

th,td{
padding:14px;
text-align:left;
border-bottom:1px solid #eee;
}

th{
color:#555;
font-size:14px;
background:#fafafa;
}

td{font-size:14px;}

.status{
padding:6px 10px;
border-radius:20px;
font-size:12px;
background:#e8f5e9;
color:#0b5d1e;
font-weight:bold;
display:inline-block;
}

.empty{
padding:20px;
text-align:center;
color:#777;
}

.footer{
position:fixed;bottom:0;left:0;right:0;height:50px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:13px;z-index:1000;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="topmenu">
<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
</div>
</div>
</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/products/create">Create Product</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<a href="/logout">Logout</a>
</div>

<div class="main">

<div class="topbar">
<div>
<h2>Admin Dashboard</h2>
<small>Welcome, <%= user ? user.name : "Administrator" %></small>
</div>
<div>
<small><%= new Date().toDateString() %></small>
</div>
</div>

<!-- FILTER -->
<form method="GET" action="/admin/dashboard" class="filters">
<select name="month">
<option value="">Month</option>
<% for(let i=1;i<=12;i++){ %>
<option value="<%= i %>" <%= query.month==i?'selected':'' %>><%= i %></option>
<% } %>
</select>

<input type="number" name="year" placeholder="Year" value="<%= query.year || '' %>">

<button type="submit">Filter</button>
</form>

<div class="cards">

<div class="card">
<h3>Total Products</h3>
<h1><%= totalProducts || 0 %></h1>
<p>Registered products</p>
</div>

<div class="card">
<h3>Monthly Orders</h3>
<h1><%= totalOrders || 0 %></h1>
<p>Year Total: <b><%= yearOrders || 0 %></b></p>
</div>

<div class="card">
<h3>Total Clients</h3>
<h1><%= totalClients || 0 %></h1>
<p>Customer accounts</p>
</div>

<div class="card">
<h3>Revenue</h3>
<h1>KES <%= revenue || 0 %></h1>
<p>Year Total: <b>KES <%= yearRevenue || 0 %></b></p>
</div>

<div class="card">
<h3>Items In Stock</h3>
<h1><%= totalItemsAvailable || 0 %></h1>
<p>All available units</p>
</div>

<div class="card">
<h3>Low Stock Products</h3>
<h1><%= lowStockCount || 0 %></h1>
<p>Need restocking soon</p>
</div>

</div>

<!-- ✅ RECENT ORDERS TABLE RESTORED -->
<div class="table-box">

<h3 class="section-title">Recent Orders</h3>

<table>

<tr>
<th>Order ID</th>
<th>Client</th>
<th>Amount</th>
<th>Status</th>
</tr>

<% if (recentOrders && recentOrders.length > 0) { %>

<% recentOrders.forEach(order => { %>

<tr>
<td><%= order._id %></td>
<td><%= order.customerName %></td>
<td>KES <%= order.totalAmount %></td>
<td><span class="status"><%= order.status %></span></td>
</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="4" class="empty">No recent orders found</td>
</tr>

<% } %>

</table>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(event){
event.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click",function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});
</script>

</body>
</html>