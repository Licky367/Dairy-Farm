<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}

body{
background:#f4f6f8;
min-height:100vh;
}

.header{
position:fixed;
top:0;left:0;right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
}

.topmenu{
position:fixed;
top:70px;left:0;right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

.profile-box{position:relative;}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.profile-box.active .dropdown{
display:block;
}

.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
transition:.3s;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

.overlay{
position:fixed;
top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{display:block;}

.main{
padding:150px 25px 80px;
}

.topbar{
background:white;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:25px;
}

.card{
background:white;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.card h3{
color:#666;
margin-bottom:10px;
font-size:15px;
}

.card h1{
color:#0b5d1e;
font-size:30px;
}

.table-box{
background:white;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
overflow:auto;
}

table{
width:100%;
border-collapse:collapse;
}

th,td{
padding:14px;
text-align:left;
border-bottom:1px solid #eee;
}

th{
color:#555;
}

.status{
padding:6px 10px;
border-radius:20px;
font-size:13px;
background:#e8f5e9;
color:#0b5d1e;
}

.empty{
padding:20px;
text-align:center;
color:#777;
}

.footer{
position:fixed;
bottom:0;left:0;right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="topmenu">

<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
</div>
</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/products/create">Create Product</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<a href="/logout">Logout</a>
</div>

<div class="main">

<div class="topbar">
<h2>Admin Dashboard</h2>
<div>Welcome, <%= user ? user.name : "" %></div>
</div>

<div class="cards">

<div class="card">
<h3>Total Products</h3>
<h1><%= totalProducts || 0 %></h1>
</div>

<div class="card">
<h3>Total Orders</h3>
<h1><%= totalOrders || 0 %></h1>
</div>

<div class="card">
<h3>Total Clients</h3>
<h1><%= totalClients || 0 %></h1>
</div>

<div class="card">
<h3>Revenue</h3>
<h1>KES <%= revenue || 0 %></h1>
</div>

</div>

<div class="table-box">

<h3 style="margin-bottom:20px;">Recent Orders</h3>

<table>

<tr>
<th>Order ID</th>
<th>Client</th>
<th>Amount</th>
<th>Status</th>
</tr>

<% if (recentOrders && recentOrders.length > 0) { %>

<% recentOrders.forEach(order => { %>

<tr>
<td><%= order.id %></td>
<td><%= order.clientName %></td>
<td>KES <%= order.amount %></td>
<td>
<span class="status"><%= order.status %></span>
</td>
</tr>

<% }) %>

<% } else { %>

<tr>
<td colspan="4" class="empty">No recent orders found</td>
</tr>

<% } %>

</table>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(event){
event.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click",function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});
</script>

</body>
</html>