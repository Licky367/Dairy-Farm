<% layout('layout', { title: 'Edit Product' }) %>

<style>
.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
}

.form-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
max-width:1000px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:15px;
}

.field{
display:flex;
flex-direction:column;
gap:7px;
}

label{
font-size:14px;
font-weight:bold;
color:#444;
}

input,
textarea{
width:100%;
padding:14px;
border:1px solid #ddd;
border-radius:10px;
outline:none;
font-size:15px;
background:#fff;
}

input:focus,
textarea:focus{
border-color:#0b5d1e;
}

textarea{
resize:vertical;
min-height:130px;
}

.preview{
width:180px;
height:180px;
object-fit:cover;
border-radius:12px;
border:1px solid #eee;
margin-top:8px;
background:#f3f3f3;
}

.preview-box{
margin-top:10px;
padding:14px;
background:#f8f8f8;
border-radius:12px;
font-size:14px;
color:#444;
line-height:1.7;
}

.stock-box{
margin-top:10px;
padding:12px;
border-radius:12px;
font-size:14px;
font-weight:bold;
display:inline-block;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

.actions{
margin-top:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

button,
.btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:10px;
cursor:pointer;
font-size:15px;
text-decoration:none;
display:inline-block;
}

.btn-secondary{
background:#1565c0;
}
</style>

<div class="topbar">
<h2>Edit Product</h2>

<a href="/admin/products" class="btn btn-secondary">
Back to Products
</a>
</div>

<div class="form-box">

<form action="/admin/products/update/<%= product.id %>" method="POST" enctype="multipart/form-data">

<div class="grid">

<div class="field">
<label>Product Name</label>
<input type="text" name="name" value="<%= product.name %>" required>
</div>

<!-- ✅ CATEGORY (READ-ONLY) -->
<div class="field">
<label>Category</label>
<input type="text" name="category" value="<%= product.category %>" readonly>
</div>

<!-- ✅ PRODUCT UNITS -->
<div class="field">
<label>Product Unit</label>
<input type="number" name="productUnits"
value="<%= product.productUnits || 0 %>"
placeholder="Enter the units for this product"
required>
</div>

<div class="field">
<label>Selling Price (KES)</label>
<input type="number" name="cost" id="cost" value="<%= product.cost %>" required oninput="calculateDeposit()">
</div>

<!-- ✅ PURCHASE PRICE (READONLY) -->
<div class="field">
<label>Purchase Price (KES)</label>
<input type="number" name="purchasePrice"
value="<%= product.purchasePrice || 0 %>"
readonly>
</div>

<div class="field">
<label>Deposit Percentage</label>
<input type="number" name="depositPercentage" id="depositPercentage" value="<%= product.depositPercentage %>" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Items Available</label>
<input type="number" name="itemsAvailable" value="<%= product.itemsAvailable || 0 %>" min="0" required>
</div>

<div class="field">
<label>Upload New Image</label>
<input type="file" name="image">
</div>

</div>

<div class="field" style="margin-top:15px;">
<label>Description</label>
<textarea name="description" required><%= product.description %></textarea>
</div>

<div class="field" style="margin-top:15px;">
<label>Current Image</label>

<% if(product.image){ %>
<img src="<%= product.image %>" class="preview">
<% } else { %>
<p>No image available</p>
<% } %>

</div>

<div class="preview-box">
Estimated Deposit Amount:
<b>KES <span id="depositAmount"><%= product.depositAmount || 0 %></span></b>
</div>

<% if((product.itemsAvailable || 0) === 0){ %>
<div class="stock-box outstock">Out of Stock</div>

<% } else if((product.itemsAvailable || 0) <= 5){ %>
<div class="stock-box lowstock">Low Stock</div>

<% } else { %>
<div class="stock-box instock">In Stock</div>
<% } %>

<div class="actions">
<button type="submit">Update Product</button>

<a href="/admin/products" class="btn btn-secondary">
Cancel
</a>
</div>

</form>

</div>

<script>
function calculateDeposit(){
let cost = Number(document.getElementById("cost").value) || 0;
let percent = Number(document.getElementById("depositPercentage").value) || 0;
let total = (cost * percent) / 100;

document.getElementById("depositAmount").innerText =
total.toLocaleString();
}
</script>