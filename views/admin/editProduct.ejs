<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Product</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f8;
min-height:100vh;
color:#222;
}

.header{
position:fixed;
top:0;
left:0;
right:0;
height:70px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
font-weight:bold;
z-index:1000;
text-align:center;
padding:0 15px;
}

.topmenu{
position:fixed;
top:70px;
left:0;
right:0;
height:60px;
background:#fff;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.menu-btn{
font-size:28px;
cursor:pointer;
color:#0b5d1e;
font-weight:bold;
}

.profile-box{
position:relative;
}

.profile-btn{
background:#0b5d1e;
color:#fff;
border:none;
padding:10px 16px;
border-radius:30px;
cursor:pointer;
font-size:14px;
}

.dropdown{
position:absolute;
right:0;
top:48px;
width:180px;
background:#fff;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
overflow:hidden;
}

.dropdown a{
display:block;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.dropdown a:hover{
background:#f7f7f7;
}

.profile-box.active .dropdown{
display:block;
}

.sidebar{
position:fixed;
top:0;
left:-280px;
width:260px;
height:100%;
background:#0b5d1e;
padding:140px 20px 20px;
transition:.35s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{
left:0;
}

.sidebar a{
display:block;
color:#fff;
text-decoration:none;
padding:14px;
margin-bottom:10px;
border-radius:10px;
transition:.3s;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,.35);
display:none;
z-index:1100;
}

.overlay.active{
display:block;
}

.main{
padding:150px 25px 80px;
}

.topbar{
background:#fff;
padding:20px;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,.05);
margin-bottom:25px;
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
}

.form-box{
background:#fff;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:15px;
}

.field{
display:flex;
flex-direction:column;
gap:7px;
}

label{
font-size:14px;
font-weight:bold;
color:#444;
}

input,
textarea{
width:100%;
padding:14px;
border:1px solid #ddd;
border-radius:10px;
outline:none;
font-size:15px;
background:#fff;
}

input:focus,
textarea:focus{
border-color:#0b5d1e;
}

textarea{
resize:vertical;
min-height:130px;
}

.preview{
width:180px;
height:180px;
object-fit:cover;
border-radius:12px;
border:1px solid #eee;
margin-top:8px;
background:#f3f3f3;
}

.preview-box{
margin-top:10px;
padding:14px;
background:#f8f8f8;
border-radius:12px;
font-size:14px;
color:#444;
line-height:1.7;
}

.stock-box{
margin-top:10px;
padding:12px;
border-radius:12px;
font-size:14px;
font-weight:bold;
display:inline-block;
}

.instock{
background:#e8f5e9;
color:#0b5d1e;
}

.lowstock{
background:#fff3cd;
color:#8a6d00;
}

.outstock{
background:#fdecea;
color:#b42318;
}

.actions{
margin-top:20px;
display:flex;
gap:10px;
flex-wrap:wrap;
}

button,
.btn{
background:#0b5d1e;
color:#fff;
padding:13px 18px;
border:none;
border-radius:10px;
cursor:pointer;
font-size:15px;
text-decoration:none;
display:inline-block;
}

.btn-secondary{
background:#1565c0;
}

.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:50px;
background:#0b5d1e;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:13px;
z-index:1000;
padding:0 10px;
text-align:center;
}

@media(max-width:768px){

.main{
padding:145px 15px 80px;
}

.header{
font-size:18px;
}

.topbar{
flex-direction:column;
align-items:flex-start;
}

.profile-btn{
font-size:13px;
padding:8px 12px;
}

.preview{
width:100%;
height:auto;
max-height:240px;
}

}
</style>
</head>

<body>

<div class="header">Corevester Investments Limited</div>

<div class="topmenu">

<div class="menu-btn" onclick="openSidebar()">☰</div>

<div class="profile-box" id="profileBox">
<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
</div>
</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">
<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/products/create">Create Product</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<a href="/logout">Logout</a>
</div>

<div class="main">

<div class="topbar">
<h2>Edit Product</h2>

<a href="/admin/products" class="btn btn-secondary">
Back to Products
</a>
</div>

<div class="form-box">

<form action="/admin/products/update/<%= product.id %>" method="POST" enctype="multipart/form-data">

<div class="grid">

<div class="field">
<label>Product Name</label>
<input type="text" name="name" value="<%= product.name %>" required>
</div>

<div class="field">
<label>Category</label>
<input type="text" name="category" value="<%= product.category %>" required>
</div>

<div class="field">
<label>Cost (KES)</label>
<input type="number" name="cost" id="cost" value="<%= product.cost %>" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Deposit Percentage</label>
<input type="number" name="depositPercentage" id="depositPercentage" value="<%= product.depositPercentage %>" required oninput="calculateDeposit()">
</div>

<div class="field">
<label>Items Available</label>
<input type="number" name="itemsAvailable" value="<%= product.itemsAvailable || 0 %>" min="0" required>
</div>

<div class="field">
<label>Upload New Image</label>
<input type="file" name="image">
</div>

</div>

<div class="field" style="margin-top:15px;">
<label>Description</label>
<textarea name="description" required><%= product.description %></textarea>
</div>

<div class="field" style="margin-top:15px;">
<label>Current Image</label>

<% if(product.image){ %>
<img src="<%= product.image %>" class="preview">
<% } else { %>
<p>No image available</p>
<% } %>

</div>

<div class="preview-box">
Estimated Deposit Amount:
<b>KES <span id="depositAmount"><%= product.depositAmount || 0 %></span></b>
</div>

<% if((product.itemsAvailable || 0) === 0){ %>
<div class="stock-box outstock">Out of Stock</div>

<% } else if((product.itemsAvailable || 0) <= 5){ %>
<div class="stock-box lowstock">Low Stock</div>

<% } else { %>
<div class="stock-box instock">In Stock</div>
<% } %>

<div class="actions">
<button type="submit">Update Product</button>

<a href="/admin/products" class="btn btn-secondary">
Cancel
</a>
</div>

</form>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(event){
event.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click",function(e){
const box=document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});

function calculateDeposit(){
let cost = Number(document.getElementById("cost").value) || 0;
let percent = Number(document.getElementById("depositPercentage").value) || 0;
let total = (cost * percent) / 100;

document.getElementById("depositAmount").innerText =
total.toLocaleString();
}
</script>

</body>
</html>