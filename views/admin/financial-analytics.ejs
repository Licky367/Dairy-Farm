<% layout('layout', { title: 'Financial Management' }) %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.container{padding:20px;}
.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:15px;margin-bottom:25px;}
.card{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}
.card h3{font-size:14px;color:#666;}

.grid{display:grid;gap:20px;}
.box{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}

.chart-header{display:flex;justify-content:space-between;align-items:center;}
.back-btn{display:none;padding:6px 12px;background:#0b5d1e;color:#fff;border:none;border-radius:6px;cursor:pointer;}
.back-btn.active{display:inline-block;}

table{width:100%;border-collapse:collapse;}
th,td{padding:10px;border-bottom:1px solid #eee;}
tfoot td{font-weight:bold;background:#f8f8f8;}

form{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;}
form input,form select,form button{
padding:10px;border-radius:8px;border:1px solid #ddd;
}
form button{background:#0b5d1e;color:#fff;border:none;cursor:pointer;}

.hidden{display:none;}

/* =========================
   TOP PRODUCTS SCROLL FIX
========================= */
tbody {
    display: block;
    max-height: 350px;
    overflow-y: auto;
}

thead, tfoot, tbody tr {
    display: table;
    width: 100%;
    table-layout: fixed;
}

@media (max-width:768px){.cards{grid-template-columns:1fr;}}
</style>

<div class="container">

<!-- FILTER -->
<form id="filterForm">

    <select id="timeFilter">
        <option value="custom">Custom Month</option>
        <option value="today">Today</option>
        <option value="week">This Week</option>
        <option value="month">This Month</option>
        <option value="year">This Year</option>
    </select>

    <input type="number" id="monthInput" placeholder="Month (1-12)" min="1" max="12">
    <input type="number" id="yearInput" placeholder="Year" min="2000">

    <select id="metricFilter">
        <option value="revenue">Revenue</option>
        <option value="profit">Profit</option>
        <option value="netProfit">Net Profit</option>
    </select>

    <button type="submit">Apply</button>
</form>

<!-- CARDS -->
<div class="cards">
    <div class="card"><h3>Revenue</h3><h2>KES <%= financial.revenue %></h2></div>
    <div class="card"><h3>Profit</h3><h2>KES <%= financial.profit %></h2></div>
    <div class="card"><h3>Net Profit</h3><h2>KES <%= financial.netProfit %></h2></div>
    <div class="card"><h3>Orders</h3><h2><%= financial.orders %></h2></div>
</div>

<!-- CHARTS -->
<div class="grid">

<div class="box">
    <div class="chart-header">
        <h3 id="majorTitle">Major Category Performance</h3>
        <button id="backBtn" class="back-btn" type="button">Back</button>
    </div>
    <canvas id="majorChart"></canvas>
</div>

<div class="box">
    <h3 id="categoryTitle">Category Performance</h3>
    <canvas id="categoryChart"></canvas>
</div>

</div>

<!-- TOP PRODUCTS -->
<div class="box" style="margin-top:20px;">
<h3 id="productTitle">Top Products</h3>

<table>
<thead>
<tr>
<th>Product</th>
<th id="metricColTitle">Revenue</th>
<th>Units</th>
</tr>
</thead>

<tbody id="productTableBody"></tbody>

<tfoot>
<tr>
<td>Total</td>
<td id="totalMetric">0</td>
<td>-</td>
</tr>
</tfoot>
</table>
</div>

<!-- =========================
     DEMAND CURVE SECTION
========================= -->
<div class="box" style="margin-top:20px;">
    <h3>Demand Curve</h3>

    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <select id="demandView">
            <option value="global">Global</option>
            <option value="major">Major Category</option>
            <option value="category">Category</option>
        </select>

        <select id="demandSelector"></select>
    </div>

    <canvas id="demandChart"></canvas>
</div>

</div>

<script>

let majorData = <%- JSON.stringify(majorCategoryStats || []) %>;
let categoryData = <%- JSON.stringify(categoryStats || []) %>;
let productData = <%- JSON.stringify(productStats || []) %>;

let demandData = <%- JSON.stringify(demandCurves || null) %>;

let majorChart;
let categoryChart;
let demandChart;

let currentMetric = "revenue";
let currentMajorCategory = null;

/* =========================
   PRODUCT TABLE
========================= */
function renderProducts(data, title="Top Products") {

    const tbody = document.getElementById("productTableBody");
    tbody.innerHTML = "";

    let totalMetric = 0;

    const displayed = [...data]
        .sort((a,b)=>(Number(b[currentMetric] || 0))-(Number(a[currentMetric] || 0)))
        .slice(0,10);

    displayed.forEach(p => {

        const metricValue = Number(p[currentMetric] || 0);
        totalMetric += metricValue;

        tbody.innerHTML += `
            <tr>
                <td>${p.name || "Unknown"}</td>
                <td>${metricValue}</td>
                <td>${p.unitsSold || 0}</td>
            </tr>
        `;
    });

    document.getElementById("productTitle").innerText = title;
    document.getElementById("totalMetric").innerText = totalMetric;
}

/* =========================
   CATEGORY + MAJOR CHARTS
   (UNCHANGED)
========================= */
function renderCategory(data, label="Category Performance") {

    document.getElementById("categoryTitle").innerText = label;

    if(categoryChart) categoryChart.destroy();

    categoryChart = new Chart(
        document.getElementById("categoryChart"),
        {
            type:"bar",
            data:{
                labels:data.map(c => c.category),
                datasets:[{
                    label: currentMetric,
                    data: data.map(c => Number(c[currentMetric] || 0))
                }]
            }
        }
    );

    document.getElementById("categoryChart").onclick = function(evt){

        const points = categoryChart.getElementsAtEventForMode(
            evt,"nearest",{intersect:true},true
        );

        if(!points.length) return;

        const selectedCategory = data[points[0].index].category;

        const filteredProducts = productData.filter(p =>
            p.majorCategory === currentMajorCategory &&
            p.category === selectedCategory
        );

        renderProducts(filteredProducts,
            `Top Products - ${currentMajorCategory} / ${selectedCategory}`
        );
    };
}

function renderMajor() {

    if(majorChart) majorChart.destroy();

    majorChart = new Chart(
        document.getElementById("majorChart"),
        {
            type:"pie",
            data:{
                labels: majorData.map(m => m.majorCategory),
                datasets:[{
                    label: currentMetric,
                    data: majorData.map(m => Number(m[currentMetric] || 0))
                }]
            }
        }
    );

    document.getElementById("majorChart").onclick = function(evt){

        const points = majorChart.getElementsAtEventForMode(
            evt,"nearest",{intersect:true},true
        );

        if(!points.length) return;

        const selectedMajor = majorData[points[0].index].majorCategory;
        currentMajorCategory = selectedMajor;

        const filteredCategories = categoryData.filter(c => c.majorCategory === selectedMajor);
        const filteredProducts = productData.filter(p => p.majorCategory === selectedMajor);

        renderCategory(filteredCategories, `${selectedMajor} Categories`);
        renderProducts(filteredProducts, `Top Products - ${selectedMajor}`);

        document.getElementById("backBtn").classList.add("active");
    };
}

function resetView(){
    currentMajorCategory = null;
    renderCategory(categoryData, "Category Performance");
    renderProducts(productData, "Top Products");
    document.getElementById("backBtn").classList.remove("active");
}

/* =========================
   DEMAND CURVE
========================= */
function renderDemandCurve(data) {

    if (demandChart) demandChart.destroy();

    demandChart = new Chart(
        document.getElementById("demandChart"),
        {
            type: "line",
            data: {
                labels: data.map(d => d.price),
                datasets: [{
                    label: "Demand",
                    data: data.map(d => d.demand),
                    tension: 0.4
                }]
            }
        }
    );
}

function initDemand() {

    if (!demandData) return;

    const view = document.getElementById("demandView");
    const selector = document.getElementById("demandSelector");

    function update() {

        selector.innerHTML = "";

        if (view.value === "global") {
            selector.style.display = "none";
            renderDemandCurve(demandData.global || []);
        }

        if (view.value === "major") {
            selector.style.display = "inline-block";

            demandData.majorCategory.forEach(m => {
                const opt = document.createElement("option");
                opt.value = m.majorCategory;
                opt.text = m.majorCategory;
                selector.appendChild(opt);
            });

            renderDemandCurve(demandData.majorCategory[0]?.curve || []);
        }

        if (view.value === "category") {
            selector.style.display = "inline-block";

            demandData.category.forEach(c => {
                const opt = document.createElement("option");
                opt.value = c.categoryKey;
                opt.text = c.categoryKey;
                selector.appendChild(opt);
            });

            renderDemandCurve(demandData.category[0]?.curve || []);
        }
    }

    view.addEventListener("change", update);

    selector.addEventListener("change", () => {

        if (view.value === "major") {
            const found = demandData.majorCategory.find(m => m.majorCategory === selector.value);
            renderDemandCurve(found?.curve || []);
        }

        if (view.value === "category") {
            const found = demandData.category.find(c => c.categoryKey === selector.value);
            renderDemandCurve(found?.curve || []);
        }
    });

    update();
}

/* =========================
   START
========================= */
renderMajor();
resetView();
initDemand();

</script>