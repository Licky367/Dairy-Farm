<% layout('layout', { title: 'Financial Management' }) %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.container{padding:20px;}
.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:15px;margin-bottom:25px;}
.card{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}
.card h3{font-size:14px;color:#666;}

.grid{display:grid;gap:20px;}
.box{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}

.chart-header{display:flex;justify-content:space-between;align-items:center;}
.back-btn{display:none;padding:6px 12px;background:#0b5d1e;color:#fff;border:none;border-radius:6px;}
.back-btn.active{display:inline-block;}

table{width:100%;border-collapse:collapse;}
th,td{padding:10px;border-bottom:1px solid #eee;}
tfoot td{font-weight:bold;background:#f8f8f8;}

form{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;}
form input,form select,form button{
padding:10px;border-radius:8px;border:1px solid #ddd;
}
form button{background:#0b5d1e;color:#fff;border:none;}

@media (max-width:768px){.cards{grid-template-columns:1fr;}}
</style>

<div class="container">

<!-- FILTER -->
<form id="filterForm" onsubmit="applyFilters(event)">

    <select id="timeFilter">
        <option value="custom">Custom Month</option>
        <option value="today">Today</option>
        <option value="week">This Week</option>
        <option value="month">This Month</option>
        <option value="year">This Year</option>
    </select>

    <input type="number" id="monthInput" placeholder="Month (1-12)">
    <input type="number" id="yearInput" placeholder="Year">

    <select id="metricFilter">
        <option value="revenue">Revenue</option>
        <option value="profit">Profit</option>
        <option value="netProfit">Net Profit</option>
    </select>

    <button type="submit">Apply</button>
</form>

<!-- CARDS -->
<div class="cards">
    <div class="card"><h3>Revenue</h3><h2>KES <%= financial.revenue %></h2></div>
    <div class="card"><h3>Profit</h3><h2>KES <%= financial.profit %></h2></div>
    <div class="card"><h3>Net Profit</h3><h2>KES <%= financial.netProfit %></h2></div>
    <div class="card"><h3>Orders</h3><h2><%= financial.orders %></h2></div>
</div>

<!-- CHARTS -->
<div class="grid">

<div class="box">
    <div class="chart-header">
        <h3>Major Category Performance</h3>
        <button id="backBtn" class="back-btn" onclick="resetView()">Back</button>
    </div>
    <canvas id="majorChart"></canvas>
</div>

<div class="box">
    <h3 id="categoryTitle">Category Performance</h3>
    <canvas id="categoryChart"></canvas>
</div>

</div>

<!-- TABLE -->
<div class="box" style="margin-top:20px;">
<h3 id="productTitle">Top Products</h3>

<table>
<thead>
<tr>
<th>Product</th>
<th>Revenue</th>
<th>Profit</th>
<th>Units</th>
</tr>
</thead>

<tbody id="productTableBody"></tbody>

<tfoot>
<tr>
<td>Total</td>
<td id="totalRevenue">0</td>
<td id="totalProfit">0</td>
<td>-</td>
</tr>
</tfoot>
</table>
</div>

</div>

<script>

let majorData = <%- JSON.stringify(majorCategoryStats) %>;
let categoryData = <%- JSON.stringify(categoryStats) %>;
let productData = <%- JSON.stringify(productStats) %>;

let majorChart;
let categoryChart;

let currentMetric = "revenue";

/* =========================
   PRODUCT TABLE
========================= */
function renderProducts(data, title="Top Products") {

    const tbody = document.getElementById("productTableBody");
    tbody.innerHTML = "";

    let totalRevenue = 0;
    let totalProfit = 0;

    const displayed = [...data]
        .sort((a,b)=>(b[currentMetric] || 0)-(a[currentMetric] || 0))
        .slice(0,10);

    displayed.forEach(p => {

        const revenue = p.revenue || 0;
        const profit = p.profit || 0;

        totalRevenue += revenue;
        totalProfit += profit;

        tbody.innerHTML += `
            <tr>
                <td>${p.name}</td>
                <td>${revenue}</td>
                <td>${profit}</td>
                <td>${p.unitsSold || 0}</td>
            </tr>
        `;
    });

    document.getElementById("productTitle").innerText = title;
    document.getElementById("totalRevenue").innerText = totalRevenue;
    document.getElementById("totalProfit").innerText = totalProfit;
}

/* =========================
   CATEGORY CHART
========================= */
function renderCategory(data, label="Category Performance") {

    document.getElementById("categoryTitle").innerText = label;

    if(categoryChart) categoryChart.destroy();

    categoryChart = new Chart(
        document.getElementById("categoryChart"),
        {
            type:"bar",
            data:{
                labels:data.map(c => c.category),
                datasets:[{
                    label: currentMetric,
                    data: data.map(c => c[currentMetric] || 0)
                }]
            }
        }
    );

    document.getElementById("categoryChart").onclick = function(evt){

        const points = categoryChart.getElementsAtEventForMode(
            evt,"nearest",{intersect:true},true
        );

        if(!points.length) return;

        const selected = data[points[0].index].category;

        renderProducts(
            productData.filter(p => p.category === selected),
            "Top Products - " + selected
        );
    };
}

/* =========================
   MAJOR CHART
========================= */
function renderMajor() {

    if(majorChart) majorChart.destroy();

    majorChart = new Chart(
        document.getElementById("majorChart"),
        {
            type:"pie",
            data:{
                labels: majorData.map(m => m.majorCategory),
                datasets:[{
                    data: majorData.map(m => m[currentMetric] || 0)
                }]
            }
        }
    );

    document.getElementById("majorChart").onclick = function(evt){

        const points = majorChart.getElementsAtEventForMode(
            evt,"nearest",{intersect:true},true
        );

        if(!points.length) return;

        const selected = majorData[points[0].index].majorCategory;

        renderCategory(
            categoryData.filter(c => c.majorCategory === selected),
            selected + " Categories"
        );

        renderProducts(
            productData.filter(p => p.majorCategory === selected),
            "Top Products - " + selected
        );

        document.getElementById("backBtn").classList.add("active");
    };
}

/* =========================
   FILTERS
========================= */
function applyFilters(e){
    e.preventDefault();

    currentMetric = document.getElementById("metricFilter").value;

    console.log({
        time: document.getElementById("timeFilter").value,
        month: document.getElementById("monthInput").value,
        year: document.getElementById("yearInput").value,
        metric: currentMetric
    });

    resetView();
    renderMajor();
}

/* =========================
   RESET VIEW
========================= */
function resetView(){

    renderCategory(categoryData);
    renderProducts(productData);

    document.getElementById("backBtn").classList.remove("active");
}

/* =========================
   INIT
========================= */
renderMajor();
renderCategory(categoryData);
renderProducts(productData);

</script>