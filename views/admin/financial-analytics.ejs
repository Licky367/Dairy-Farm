<% layout('layout', { title: 'Financial Management' }) %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.container{padding:20px;}
.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:15px;margin-bottom:25px;}
.card{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}
.card h3{font-size:14px;color:#666;}

.grid{display:grid;gap:20px;}
.box{background:white;padding:20px;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,0.05);}

.chart-header{display:flex;justify-content:space-between;align-items:center;}
.back-btn{display:none;padding:6px 12px;background:#0b5d1e;color:#fff;border:none;border-radius:6px;cursor:pointer;}
.back-btn.active{display:inline-block;}

table{width:100%;border-collapse:collapse;}
th,td{padding:10px;border-bottom:1px solid #eee;}
tfoot td{font-weight:bold;background:#f8f8f8;}

form{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;}
form input,form select,form button{
padding:10px;border-radius:8px;border:1px solid #ddd;
}
form button{background:#0b5d1e;color:#fff;border:none;cursor:pointer;}

tbody {
    display: block;
    max-height: 350px;
    overflow-y: auto;
}

thead, tfoot, tbody tr {
    display: table;
    width: 100%;
    table-layout: fixed;
}

@media (max-width:768px){.cards{grid-template-columns:1fr;}}
</style>

<div class="container">

<!-- FILTER -->
<form id="filterForm">

    <select id="timeFilter">
        <option value="custom">Custom Month</option>
        <option value="today">Today</option>
        <option value="week">This Week</option>
        <option value="month">This Month</option>
        <option value="year">This Year</option>
    </select>

    <input type="number" id="monthInput" placeholder="Month (1-12)" min="1" max="12">
    <input type="number" id="yearInput" placeholder="Year" min="2000">

    <select id="metricFilter">
        <option value="revenue">Revenue</option>
        <option value="profit">Profit</option>
        <option value="netProfit">Net Profit</option>
    </select>

    <button type="submit">Apply</button>
</form>

<!-- CARDS -->
<div class="cards">

    <div class="card">
        <h3>Revenue</h3>
        <h2>KES <%= financial.revenue || 0 %></h2>
    </div>

    <div class="card">
        <h3>Profit</h3>
        <h2>KES <%= financial.profit || 0 %></h2>
    </div>

    <div class="card">
        <h3>Net Profit</h3>
        <h2>KES <%= financial.netProfit || 0 %></h2>
    </div>

    <div class="card">
        <h3>Orders</h3>
        <h2><%= financial.orders || 0 %></h2>
    </div>

</div>

<!-- CHARTS -->
<div class="grid">

<div class="box">
    <div class="chart-header">
        <h3 id="majorTitle">Major Category Performance</h3>
        <button id="backBtn" class="back-btn" type="button">Back</button>
    </div>
    <canvas id="majorChart"></canvas>
</div>

<div class="box">
    <h3 id="categoryTitle">Category Performance</h3>
    <canvas id="categoryChart"></canvas>
</div>

</div>

<!-- TOP PRODUCTS -->
<div class="box" style="margin-top:20px;">
<h3 id="productTitle">Top Products</h3>

<table>
<thead>
<tr>
<th>Product</th>
<th id="metricColTitle">Revenue</th>
<th>Units</th>
</tr>
</thead>

<tbody id="productTableBody"></tbody>

<tfoot>
<tr>
<td>Total</td>
<td id="totalMetric">0</td>
<td>-</td>
</tr>
</tfoot>
</table>
</div>

<!-- DEMAND CURVE -->
<div class="box" style="margin-top:20px;">
    <h3>Demand Curve</h3>

    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <select id="demandView">
            <option value="global">Global</option>
            <option value="major">Major Category</option>
            <option value="category">Category</option>
        </select>

        <select id="demandSelector"></select>
    </div>

    <canvas id="demandChart"></canvas>
</div>

</div>

<script>

let majorData = <%- JSON.stringify(majorCategoryStats || []) %>;
let categoryData = <%- JSON.stringify(categoryStats || []) %>;
let productData = <%- JSON.stringify(productStats || []) %>;
let demandData = <%- JSON.stringify(demandCurves || null) %>;

let majorChart;
let categoryChart;
let demandChart;

let currentMetric = "revenue";
let currentMajorCategory = null;

/* =========================
   METRIC LABEL
========================= */
function getMetricLabel() {
    if (currentMetric === "revenue") return "Revenue";
    if (currentMetric === "profit") return "Profit";
    return "Net Profit";
}

function updateMetricUI() {
    document.getElementById("metricColTitle").innerText = getMetricLabel();
}

/* =========================
   PRODUCT TABLE
========================= */
function renderProducts(data, title="Top Products") {

    const tbody = document.getElementById("productTableBody");
    tbody.innerHTML = "";

    let totalMetric = 0;

    const sorted = [...data]
        .sort((a,b)=>(Number(b[currentMetric] || 0))-(Number(a[currentMetric] || 0)))
        .slice(0,10);

    sorted.forEach(p => {

        const value = Number(p[currentMetric] || 0);
        totalMetric += value;

        tbody.innerHTML += `
            <tr>
                <td>${p.name || "Unknown"}</td>
                <td>${value}</td>
                <td>${p.unitsSold || 0}</td>
            </tr>
        `;
    });

    document.getElementById("productTitle").innerText = title;
    document.getElementById("totalMetric").innerText = totalMetric;

    updateMetricUI();
}

/* =========================
   UPDATE CARDS SAFELY
========================= */
function updateCards(financial) {

    if (!financial) return;

    document.querySelectorAll(".card")[0].querySelector("h2").innerText =
        "KES " + (financial.revenue || 0);

    document.querySelectorAll(".card")[1].querySelector("h2").innerText =
        "KES " + (financial.profit || 0);

    document.querySelectorAll(".card")[2].querySelector("h2").innerText =
        "KES " + (financial.netProfit || 0);

    document.querySelectorAll(".card")[3].querySelector("h2").innerText =
        financial.orders || 0;
}

/* =========================
   INIT
========================= */
renderProducts(productData, "Top Products");
updateMetricUI();

</script>