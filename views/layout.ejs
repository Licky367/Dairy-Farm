<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "Corevester" %></title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}
body{background:#f4f6f8;min-height:100vh;}

/* HEADER */
.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;z-index:1000;
}

/* TOP MENU */
.topmenu{
position:fixed;top:70px;left:0;right:0;height:60px;
background:#fff;
display:flex;align-items:center;justify-content:space-between;
padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);
z-index:999;
}

.left-menu{display:flex;align-items:center;gap:18px;}

.menu-btn{font-size:24px;cursor:pointer;color:#0b5d1e;}

.icon-group{display:flex;gap:18px;}
.icon-group a{
text-decoration:none;
color:#0b5d1e;
font-size:18px;
}

/* PROFILE */
.profile-box{position:relative;}

.profile-trigger{
display:flex;
flex-direction:column;
align-items:center;
cursor:pointer;
gap:4px;
}

.profile-avatar{
width:38px;
height:38px;
border-radius:50%;
object-fit:cover;
border:2px solid #0b5d1e;
}

.profile-name{
font-size:12px;
color:#0b5d1e;
font-weight:600;
max-width:80px;
white-space:nowrap;
overflow:hidden;
text-overflow:ellipsis;
}

.dropdown{
position:absolute;
right:0;top:55px;width:180px;
background:#fff;border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;
}

.dropdown a{
display:flex;
align-items:center;
gap:10px;
padding:14px;
text-decoration:none;
color:#333;
border-bottom:1px solid #eee;
}

.profile-box.active .dropdown{display:block;}

/* SIDEBAR */
.sidebar{
position:fixed;
top:130px;
left:-260px;
width:240px;
height:calc(100% - 130px - 50px);
background:#0b5d1e;
padding:20px;
transition:.3s ease;
z-index:1200;
overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar a{
display:flex;
align-items:center;
gap:12px;
color:#fff;
text-decoration:none;
padding:12px;
margin-bottom:8px;
border-radius:8px;
font-size:14px;
}

.sidebar a:hover{
background:rgba(255,255,255,.15);
}

/* OVERLAY */
.overlay{
position:fixed;
top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,.35);
display:none;z-index:1100;
}
.overlay.active{display:block;}

/* MAIN */
.main{
padding:150px 20px 80px;
}

/* AUTH PAGE MAIN */
.main.auth{
padding:40px 20px;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

/* FOOTER */
.footer{
position:fixed;
bottom:0;left:0;right:0;height:50px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:13px;
}
</style>
</head>

<body>

<%
const authPages = [
  "/login",
  "/signup",
  "/forgot-password",
  "/reset-password"
];
const isAuthPage = authPages.includes(req.path);
%>

<% if (!isAuthPage) { %>

<!-- HEADER -->
<div class="header">
Corevester Investments Limited
</div>

<!-- TOP MENU -->
<div class="topmenu">

<div class="left-menu">
<div class="menu-btn" onclick="openSidebar()">☰</div>

<% if(user && user.role === "client"){ %>
<div class="icon-group">
<a href="/client" title="Home">⌂</a>
<a href="/cart" title="Cart">🛍</a>
<a href="/client/orders" title="Orders">📦</a>
<a href="/client/unpaid/orders" title="Pending">⏳</a>
</div>
<% } %>

</div>

<!-- PROFILE -->
<div class="profile-box" id="profileBox">

<div class="profile-trigger" onclick="toggleProfile(event)">

<% if (user && user.profileImage) { %>
<img src="/uploads/<%= user.profileImage %>" class="profile-avatar" alt="Profile">
<% } else { %>
<img src="https://ui-avatars.com/api/?name=<%= user ? user.name : 'Profile' %>&background=0b5d1e&color=fff" class="profile-avatar" alt="Avatar">
<% } %>

<div class="profile-name">
<%= user ? user.name : "Profile" %>
</div>

</div>

<div class="dropdown">
<% if(user){ %>
<a href="/profile">👤 My Account</a>
<a href="/logout">🚪 Logout</a>
<% } else { %>
<a href="/login">🔑 Login</a>
<a href="/signup">📝 Sign Up</a>
<% } %>
</div>

</div>

</div>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

<% if(user && user.role === "admin"){ %>
<a href="/admin/dashboard">📊 Dashboard</a>
<a href="/category/create">➕ Add Category</a>
<a href="/admin/products">📦 Products</a>
<a href="/admin/products/create">🆕 Create Product</a>
<a href="/category">🗂️ Available Categories</a>
<a href="/admin/orders">🧾 Orders</a>
<a href="/admin/unpaid/orders">⏳ Pending Payments</a>
<a href="/admin/clients">👥 Clients</a>
<% } else { %>
<a href="/client">⌂ Home</a>
<a href="/cart">🛍 Cart</a>
<a href="/client/orders">📦 My Orders</a>
<a href="/client/unpaid/orders">⏳ Pending Payments</a>
<a href="/logout">🚪 Logout</a>
<% } %>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<% } %>

<!-- MAIN CONTENT -->
<div class="main <%= isAuthPage ? 'auth' : '' %>">
<%- body %>
</div>

<% if (!isAuthPage) { %>

<!-- FOOTER -->
<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
sidebar.classList.add("active");
overlay.classList.add("active");
}
function closeSidebar(){
sidebar.classList.remove("active");
overlay.classList.remove("active");
}
function toggleProfile(e){
e.stopPropagation();
profileBox.classList.toggle("active");
}
document.addEventListener("click",()=>{
profileBox.classList.remove("active");
});
</script>

<% } %>

</body>
</html>