<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "My Profile" %></title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}

body{background:#f4f6f8;min-height:100vh;}

/* HEADER */
.header{
position:fixed;top:0;left:0;right:0;height:70px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:22px;font-weight:bold;z-index:1000;
}

/* TOP MENU */
.topmenu{
position:fixed;top:70px;left:0;right:0;height:60px;
background:#fff;display:flex;align-items:center;
justify-content:space-between;padding:0 20px;
box-shadow:0 4px 12px rgba(0,0,0,.05);z-index:999;
}

.menu-btn{font-size:28px;cursor:pointer;color:#0b5d1e;font-weight:bold;}

.icon-group{
display:flex;
align-items:center;
gap:18px;
}

.icon-group a{
text-decoration:none;
font-size:20px;
color:#0b5d1e;
}

.profile-box{position:relative;}

.profile-btn{
background:#0b5d1e;color:#fff;border:none;
padding:10px 16px;border-radius:30px;
cursor:pointer;font-size:14px;
}

.dropdown{
position:absolute;right:0;top:48px;width:180px;
background:#fff;border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
display:none;overflow:hidden;
}

.dropdown a{
display:block;padding:14px;text-decoration:none;
color:#333;border-bottom:1px solid #eee;
}

.profile-box.active .dropdown{display:block;}

/* SIDEBAR */
.sidebar{
position:fixed;top:0;left:-280px;width:260px;height:100%;
background:#0b5d1e;padding:140px 20px 20px;
transition:.35s ease;z-index:1200;overflow-y:auto;
}

.sidebar.active{left:0;}

.sidebar a{
display:block;color:#fff;text-decoration:none;
padding:14px;margin-bottom:10px;border-radius:10px;
transition:.3s;
}

.sidebar a:hover{background:rgba(255,255,255,.15);}

/* OVERLAY */
.overlay{
position:fixed;top:0;left:0;right:0;bottom:0;
background:rgba(0,0,0,.35);display:none;z-index:1100;
}

.overlay.active{display:block;}

/* MAIN */
.main{padding:140px 25px 80px;}

/* PROFILE CARD */
.card{
max-width:800px;
margin:auto;
background:white;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.profile-top{
display:flex;
align-items:center;
gap:20px;
}

.avatar{
width:70px;
height:70px;
border-radius:50%;
background:#0b5d1e;
color:white;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
font-weight:bold;
}

.info h2{margin-bottom:5px;}
.info p{color:#666;font-size:14px;}

label{
display:block;
margin-top:15px;
margin-bottom:5px;
font-weight:bold;
}

input{
width:100%;
padding:12px;
border:1px solid #ddd;
border-radius:8px;
outline:none;
}

button{
margin-top:15px;
background:#0b5d1e;
color:white;
border:none;
padding:12px;
border-radius:8px;
cursor:pointer;
width:100%;
}

/* FOOTER */
.footer{
position:fixed;bottom:0;left:0;right:0;height:50px;
background:#0b5d1e;color:#fff;
display:flex;align-items:center;justify-content:center;
font-size:13px;z-index:1000;
}
</style>
</head>

<body>

<div class="header">
Corevester Investments Limited
</div>

<div class="topmenu">

<div style="display:flex;align-items:center;gap:15px;">
<div class="menu-btn" onclick="openSidebar()">☰</div>

<% if(user && user.role === "client"){ %>
<div class="icon-group">
<a href="/client">🏠</a>
<a href="/client/cart">🛒</a>
</div>
<% } %>

</div>

<div class="profile-box" id="profileBox">

<button class="profile-btn" onclick="toggleProfile(event)">
<%= user ? user.name : "Account" %>
</button>

<div class="dropdown">
<% if(user){ %>
<a href="/profile">My Account</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/login">Login</a>
<a href="/signup">Sign Up</a>
<% } %>
</div>

</div>

</div>

<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="sidebar" id="sidebar">

<% if(user && user.role === "admin"){ %>
<a href="/admin/dashboard">Dashboard</a>
<a href="/admin/products">Products</a>
<a href="/admin/products/create">Create product</a>
<a href="/admin/orders">Orders</a>
<a href="/admin/payments">Payments</a>
<a href="/admin/clients">Clients</a>
<% } else { %>
<a href="/client">Home</a>
<a href="/client/cart">Cart</a>
<a href="/profile">Profile</a>
<% } %>

<a href="/logout">Logout</a>

</div>

<div class="main">

<div class="card">

<div class="profile-top">

<div class="avatar">
<%= user && user.name ? user.name.charAt(0).toUpperCase() : "U" %>
</div>

<div class="info">
<h2><%= user ? user.name : "" %></h2>
<p><%= user ? user.email : "" %></p>
<p><%= user ? user.role : "" %></p>
</div>

</div>

<hr style="margin:25px 0;">

<h2>Edit Profile</h2>

<form action="/profile/update" method="POST" enctype="multipart/form-data">

<label>Full Name</label>
<input type="text" name="name" value="<%= user ? user.name : "" %>">

<label>Email</label>
<input type="email" name="email" value="<%= user ? user.email : "" %>">

<label>Phone</label>
<input type="text" name="phone" value="<%= user ? user.phone : "" %>">

<label>Profile Image</label>
<input type="file" name="profileImage">

<hr style="margin:20px 0;">

<h3>Change Password</h3>

<label>Old Password</label>
<input type="password" name="oldPassword">

<label>New Password</label>
<input type="password" name="newPassword">

<button type="submit">Update Profile</button>

</form>

</div>

</div>

<div class="footer">
© <%= new Date().getFullYear() %> Corevester Investments Limited
</div>

<script>
function openSidebar(){
document.getElementById("sidebar").classList.add("active");
document.getElementById("overlay").classList.add("active");
}

function closeSidebar(){
document.getElementById("sidebar").classList.remove("active");
document.getElementById("overlay").classList.remove("active");
}

function toggleProfile(e){
e.stopPropagation();
document.getElementById("profileBox").classList.toggle("active");
}

document.addEventListener("click", function(e){
const box = document.getElementById("profileBox");
if(!box.contains(e.target)){
box.classList.remove("active");
}
});
</script>

</body>
</html>