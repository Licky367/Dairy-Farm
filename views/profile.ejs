<%- include("partials/layout", { title: "My Profile" }) %>

<style>
.card{
max-width:800px;
margin:auto;
background:white;
padding:25px;
border-radius:16px;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.profile-top{
display:flex;
align-items:center;
gap:20px;
}

.avatar{
width:70px;
height:70px;
border-radius:50%;
background:#0b5d1e;
color:white;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
font-weight:bold;
}

.info h2{
margin-bottom:5px;
}

.info p{
color:#666;
font-size:14px;
}

label{
display:block;
margin-top:15px;
margin-bottom:5px;
font-weight:bold;
}

input{
width:100%;
padding:12px;
border:1px solid #ddd;
border-radius:8px;
outline:none;
}

button{
margin-top:20px;
background:#0b5d1e;
color:white;
border:none;
padding:12px;
border-radius:8px;
cursor:pointer;
width:100%;
}
</style>

<div class="card">

<div class="profile-top">

<div class="avatar">
<%= user.name.charAt(0).toUpperCase() %>
</div>

<div class="info">
<h2><%= user.name %></h2>
<p><%= user.email %></p>
<p><%= user.role %></p>
</div>

</div>

<hr style="margin:25px 0;">

<h2 style="margin-bottom:20px;">Edit Profile</h2>

<form action="/profile/update" method="POST">

<label>Full Name</label>
<input type="text" name="name" value="<%= user.name %>">

<label>Email</label>
<input type="email" name="email" value="<%= user.email %>">

<label>Phone</label>
<input type="text" name="phone" value="<%= user.phone %>">

<button type="submit">Update Profile</button>

</form>

</div>